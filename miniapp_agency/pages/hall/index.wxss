@import "../../app.wxss";

.hall-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #eaf2f8;
}

.hall-tab {
  height: 62rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-muted);
  font-size: 24rpx;
  font-weight: 950;
}

.hall-tab-active {
  background: #fff;
  color: var(--c-primary-dark);
  box-shadow: 0 8rpx 20rpx rgba(30, 54, 92, 0.1);
}

.compact-panel {
  margin-top: 14rpx;
  padding: 20rpx;
}

.market-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.market-head > view:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.market-head .muted {
  line-height: 1.35;
}

.refresh-button,
.market-head .mini-button {
  flex: 0 0 auto;
  min-width: 92rpx;
  max-width: 168rpx;
  height: 50rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  line-height: 50rpx;
}

.hall-filter-grid {
  display: grid;
  grid-template-columns: 126rpx 126rpx minmax(0, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
}

.compact-filter {
  height: 54rpx;
  min-height: 54rpx;
  padding: 0 12rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 21rpx;
  line-height: 54rpx;
}

.keyword-filter {
  min-width: 0;
}

.hall-listing-card .row-title {
  color: var(--c-primary-dark);
}

.my-order-card {
  padding: 0;
  overflow: hidden;
}

.order-tap-area {
  padding: 18rpx;
}

.inline-actions {
  padding: 14rpx 18rpx 18rpx;
  border-top: 1rpx solid var(--c-border);
  background: #f8fafc;
}

.driver-box {
  display: grid;
  gap: 6rpx;
  margin-bottom: 12rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  background: #e8fbf8;
  color: var(--c-primary-dark);
  font-size: 22rpx;
  font-weight: 850;
}

.reason-input {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  max-height: 88rpx;
  box-sizing: border-box;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border);
  background: #ffffff;
  color: var(--c-text);
  font-size: 23rpx;
  line-height: 32rpx;
}

.force-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 10rpx 12rpx;
  border-radius: 16rpx;
  background: var(--c-warning-soft);
  color: var(--c-warning);
  font-size: 22rpx;
  font-weight: 900;
}

.action-note {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: var(--c-warning);
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1.35;
}

.time-change-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 10rpx;
  margin-top: 10rpx;
}

.time-change-input {
  width: 100%;
  height: 56rpx;
  min-height: 56rpx;
  padding: 0 12rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 21rpx;
  line-height: 56rpx;
}

.card-action-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 12rpx;
}

.card-action-row:empty {
  display: none;
}

.action-hint {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: var(--c-muted);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.4;
}

.small-button {
  width: auto;
  min-width: 0;
  height: 52rpx;
  margin: 0;
  padding: 0 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid #bfdbfe;
  color: var(--c-primary);
  background: #ffffff;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.small-button.primary {
  color: #fff;
  background: var(--c-primary);
}

.small-button.danger {
  color: var(--c-danger);
  border-color: #fecaca;
  background: #ffffff;
}

.small-button::after {
  border: 0;
}
