.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 10rpx 24rpx calc(6rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(244, 247, 251, 0) 0%, rgba(244, 247, 251, 0.92) 34%, rgba(244, 247, 251, 1) 100%);
}

.tab-inner {
  height: 88rpx;
  border: 1rpx solid rgba(210, 221, 235, 0.92);
  border-radius: 30rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  align-items: center;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(16, 32, 51, 0.12);
  backdrop-filter: blur(18rpx);
}

.tab-item {
  height: 68rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: #65758b;
  font-size: 22rpx;
  font-weight: 850;
}

.tab-mark {
  width: 28rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: transparent;
}

.tab-active {
  color: #0f766e;
  background: #ecfeff;
}

.tab-active .tab-mark {
  background: #0f766e;
}
