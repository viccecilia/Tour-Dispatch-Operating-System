<view class="tab-shell">
  <view class="tab-inner">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-mark"></view>
      <text>{{item.text}}</text>
    </view>
  </view>
</view>
