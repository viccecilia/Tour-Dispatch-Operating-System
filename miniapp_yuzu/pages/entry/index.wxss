.entry-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.port-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.port-card {
  padding: 26rpx;
  border: 1rpx solid #dbe6f2;
  border-radius: 24rpx;
  background: #f8fbff;
}

.port-card.agency {
  border-color: #bfe7df;
  background: #f0fdfa;
}

.port-card.dispatch {
  border-color: #bfd4ff;
  background: #edf4ff;
}

.port-title {
  font-size: 34rpx;
  font-weight: 950;
}

.port-copy {
  margin-top: 8rpx;
  color: #60728a;
  font-size: 24rpx;
  line-height: 1.45;
}
