@import "../../app.wxss";

.info-hero {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  box-shadow: 0 18rpx 42rpx rgba(20, 184, 166, 0.22);
}

.info-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.info-tab {
  min-height: 142rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.info-tab.active {
  border-color: #0f766e;
  background: linear-gradient(180deg, #ecfdf5 0%, #ffffff 100%);
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.16);
}

.info-tab text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 850;
}

.info-tab strong {
  display: block;
  margin-top: 8rpx;
  color: #0f766e;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 1;
}

.info-tab view {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 750;
  line-height: 1.35;
}

.info-tab:nth-child(3) {
  grid-column: 1 / -1;
}

.info-panel {
  margin-top: 18rpx;
}

.info-search {
  height: 82rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.info-list {
  margin-top: 14rpx;
}

.info-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.info-body {
  margin-top: 8rpx;
  color: #475569;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.45;
}

.info-field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
}

.info-field {
  min-width: 0;
  box-sizing: border-box;
  border-radius: 18rpx;
  padding: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.info-field text {
  display: block;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 800;
}

.info-field strong {
  display: block;
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}
