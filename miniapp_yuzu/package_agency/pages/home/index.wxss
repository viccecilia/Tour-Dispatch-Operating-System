@import "../../app.wxss";

.login-panel {
  padding-top: 28rpx;
}

.hero-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-topline > view:first-child {
  min-width: 0;
  flex: 1;
}

.role-badge {
  min-width: 92rpx;
  height: 50rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
  font-size: 23rpx;
  font-weight: 950;
}

.guide-page {
  background: #f6fbf9;
}

.guide-hero {
  color: #0f3f3a;
  background: linear-gradient(135deg, #e8faf5 0%, #dff4ee 100%);
  box-shadow: 0 14rpx 30rpx rgba(18, 92, 82, 0.1);
}

.guide-hero .hero-meta {
  color: #315c56;
  opacity: 1;
}

.guide-hero .role-badge {
  color: #0f766e;
  border-color: rgba(15, 118, 110, 0.34);
  background: rgba(255, 255, 255, 0.58);
}

.guide-panel {
  border-color: #d8eee8;
  box-shadow: 0 10rpx 24rpx rgba(18, 92, 82, 0.06);
}

.login-input {
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 20rpx;
  line-height: 76rpx;
  font-size: 28rpx;
}

.login-panel .button-primary {
  margin-top: 28rpx;
}

.login-button,
.logout-button {
  width: 100%;
}

.resolved-agency {
  margin-top: 14rpx;
  border-radius: 16rpx;
  padding: 14rpx 18rpx;
  background: var(--c-primary-soft);
  color: var(--c-primary-dark);
  font-size: 24rpx;
  font-weight: 900;
}

.dashboard-grid {
  margin-top: 0;
}

.stats-panel {
  padding: 20rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-card {
  min-height: 132rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 22rpx;
  padding: 18rpx;
  background: var(--c-soft);
}

.quick-title {
  margin-bottom: 8rpx;
  font-size: 27rpx;
  font-weight: 950;
  color: var(--c-text);
}

.bottom-panel {
  margin-bottom: 24rpx;
}

.settings-card {
  margin-top: 18rpx;
  min-height: 96rpx;
}

.logout-button {
  margin-top: 18rpx;
}

.guide-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.guide-order-card,
.history-row {
  border: 1rpx solid var(--c-border);
  border-radius: 22rpx;
  padding: 18rpx;
  background: #fff;
}

.guide-order-card.current {
  border-color: #bfe5dc;
  background: #f0fbf7;
}

.guide-order-no {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 950;
}

.guide-time,
.guide-route {
  margin-top: 7rpx;
  color: var(--c-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.guide-route {
  color: var(--c-text);
  font-weight: 850;
}

.guest-box {
  margin-top: 14rpx;
  border-radius: 16rpx;
  padding: 14rpx;
  background: #fff;
  color: var(--c-text);
  font-size: 23rpx;
  line-height: 1.55;
}

.report-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
}

.report-button {
  height: 60rpx;
  border: 0;
  border-radius: 16rpx;
  margin: 0;
  padding: 0;
  background: #dff4ee;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 900;
}

.report-button::after {
  border: 0;
}
