@import "../../app.wxss";

.guide-hero {
  color: #0f3f3a;
  background: linear-gradient(135deg, #e8faf5 0%, #dff4ee 100%);
  box-shadow: 0 14rpx 30rpx rgba(18, 92, 82, 0.1);
}

.guide-hero .hero-meta {
  color: #315c56;
  opacity: 1;
}

.map-wrap {
  position: relative;
  margin-top: 18rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 420rpx;
}

.map-empty {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 850;
}

.tracking-search {
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  line-height: 72rpx;
  font-size: 25rpx;
}

.track-detail {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  border-radius: 20rpx;
  padding: 18rpx;
  background: var(--c-primary-soft);
  color: var(--c-primary-dark);
  font-size: 23rpx;
  font-weight: 850;
}

.detail-line {
  line-height: 1.45;
}

.report-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 10rpx;
}

.report-button {
  height: 60rpx;
  border: 0;
  border-radius: 16rpx;
  margin: 0;
  padding: 0;
  background: var(--c-primary);
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}

.report-button::after {
  border: 0;
}
