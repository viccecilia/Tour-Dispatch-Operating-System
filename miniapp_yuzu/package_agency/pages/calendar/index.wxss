@import "../../app.wxss";

.guide-hero {
  color: #0f3f3a;
  background: linear-gradient(135deg, #e8faf5 0%, #dff4ee 100%);
  box-shadow: 0 14rpx 30rpx rgba(18, 92, 82, 0.1);
}

.guide-hero .hero-meta {
  color: #315c56;
  opacity: 1;
}

.calendar-card {
  padding: 20rpx;
}

.month-header {
  display: grid;
  grid-template-columns: 58rpx 1fr 58rpx auto auto;
  align-items: center;
  gap: 10rpx;
}

.month-title {
  text-align: center;
  color: var(--c-text);
  font-size: 31rpx;
  font-weight: 950;
}

.month-button,
.today-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  margin: 0;
  background: var(--c-soft);
  color: var(--c-text);
  font-weight: 950;
}

.month-button {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  font-size: 38rpx;
  line-height: 58rpx;
}

.today-button {
  height: 58rpx;
  min-width: 82rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.refresh-button {
  min-width: 92rpx;
}

.month-button::after,
.today-button::after {
  border: 0;
}

.weekday-row,
.month-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
}

.weekday-row {
  margin-top: 18rpx;
}

.weekday {
  text-align: center;
  color: var(--c-muted);
  font-size: 21rpx;
  font-weight: 900;
}

.month-grid {
  margin-top: 10rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 22rpx;
  overflow: hidden;
  background: #fff;
}

.day-cell {
  position: relative;
  min-height: 86rpx;
  border-right: 1rpx solid var(--c-border);
  border-bottom: 1rpx solid var(--c-border);
  padding: 10rpx 8rpx;
  box-sizing: border-box;
  background: #fff;
}

.day-cell:nth-child(7n) {
  border-right: 0;
}

.day-cell:nth-last-child(-n + 7) {
  border-bottom: 0;
}

.day-muted {
  background: #f8fbff;
}

.day-muted .day-number {
  color: #b8c2d1;
}

.day-selected {
  background: #ecfeff;
  box-shadow: inset 0 0 0 3rpx var(--c-primary);
}

.day-today .day-number {
  background: var(--c-primary);
  color: #fff;
}

.day-number {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text);
  font-size: 21rpx;
  font-weight: 950;
}

.day-count {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: var(--c-accent-soft);
  color: var(--c-accent);
  text-align: center;
  line-height: 28rpx;
  font-size: 18rpx;
  font-weight: 950;
}

.dot-row {
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 14rpx;
}

.status-dot,
.legend-dot {
  border-radius: 999rpx;
}

.status-dot {
  min-width: 15rpx;
  height: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  color: #fff;
  font-size: 14rpx;
  font-weight: 950;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
  margin-top: 18rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--c-muted);
  font-size: 20rpx;
  font-weight: 850;
}

.legend-dot {
  width: 22rpx;
  height: 10rpx;
}

.order-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.order-card {
  border: 1rpx solid var(--c-border);
  border-radius: 20rpx;
  padding: 18rpx;
  background: #fff;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.order-no {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 950;
}

.order-time,
.order-route {
  margin-top: 6rpx;
  color: var(--c-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.order-route {
  color: var(--c-text);
}

.status-pill {
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
  font-size: 20rpx;
  font-weight: 950;
  white-space: nowrap;
}

.draft,
.legend-dot.draft {
  background: #e2e8f0;
  color: #334155;
}

.listed,
.legend-dot.listed {
  background: #f59e0b;
  color: #fff;
}

.claimed,
.legend-dot.claimed {
  background: #2563eb;
  color: #fff;
}

.active,
.legend-dot.active {
  background: #7c3aed;
  color: #fff;
}

.done,
.legend-dot.done {
  background: #059669;
  color: #fff;
}

.expired,
.legend-dot.expired {
  background: #dc2626;
  color: #fff;
}

.status-pill.draft {
  background: #e2e8f0;
  color: #334155;
}

.status-pill.listed {
  background: #fffbeb;
  color: #b45309;
}

.status-pill.claimed {
  background: #eff6ff;
  color: #1d4ed8;
}

.status-pill.active {
  background: #f5f3ff;
  color: #6d28d9;
}

.status-pill.done {
  background: #ecfdf5;
  color: #047857;
}

.status-pill.expired {
  background: #fef2f2;
  color: #b91c1c;
}
