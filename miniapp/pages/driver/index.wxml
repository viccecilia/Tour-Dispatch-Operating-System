<view class="page">
  <view wx:if="{{activeTab === 'home' || activeTab === 'expense' || activeTab === 'mine'}}" class="driver-hero status-{{statusMode}}">
    <view class="hero-top">
      <view class="hero-main">
        <view class="driver-name">{{driverName}}</view>
        <view class="driver-meta">{{today}} {{nowText}} · {{isOnline ? '在线' : '离线'}}</view>
      </view>
      <view class="status-pill">{{statusText}}</view>
    </view>

    <view class="hero-grid">
      <view>
        <text>当前车辆</text>
        <strong>{{selected.vehicle_display || '未绑定'}}</strong>
      </view>
      <view>
        <text>今日订单</text>
        <strong>{{assignments.length}}</strong>
      </view>
      <view>
        <text>下一单</text>
        <strong>{{selected ? selected.start_time : '--:--'}}</strong>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel loading">正在加载司机任务...</view>

  <view wx:if="{{activeTab === 'home'}}" class="tab-page home-page">
    <view wx:if="{{pendingConfirmAssignments.length > 0}}" class="confirm-card">
      <view class="confirm-eyebrow">待确认接单</view>
      <view class="confirm-headline">今天 {{pendingConfirmAssignments.length}} 单待确认</view>
      <view class="confirm-preview" wx:for="{{pendingConfirmAssignments}}" wx:key="assignment_id" wx:if="{{index < 2}}" data-id="{{item.assignment_id}}" bindtap="onSelectOrder">
        <view class="confirm-route">{{item.datetime_label}} {{item.pickup_location}} → {{item.dropoff_location}}</view>
        <view class="confirm-guest">客人：{{item.guest_name || '未填写'}} · {{item.guest_contact || '-'}}</view>
      </view>
      <view wx:if="{{pendingConfirmAssignments.length > 2}}" class="confirm-more">
        还有 {{pendingConfirmAssignments.length - 2}} 单，确认后到任务页查看全部订单
      </view>
      <button class="confirm-all-button" bindtap="confirmAllPendingAssignments">确认接单</button>
    </view>

    <view class="panel focus-panel">
      <view class="section-label">当前任务</view>
      <view wx:if="{{selected}}" class="focus-route">
        <view class="focus-time">{{selected.datetime_label}}</view>
        <view class="focus-title">{{selected.pickup_location}} → {{selected.dropoff_location}}</view>
        <view class="focus-meta">客人：{{selected.guest_name || '未填写'}} · {{selected.guest_contact || '-'}}</view>
      </view>
      <view wx:if="{{!selected}}" class="focus-empty">
        <view class="focus-title">本人没有订单</view>
        <view class="focus-meta">当前没有需要执行的任务。</view>
      </view>
    </view>

    <view class="status-strip">
      <view><text>出入库</text><strong>{{statusText}}</strong></view>
      <view><text>清扫</text><strong>{{workbench.cleaning_status || '未清扫'}}</strong></view>
      <view><text>酒测</text><strong>{{workbench.alcohol_status || '未确认'}}</strong></view>
    </view>

    <view class="panel timeline-panel">
      <view class="panel-header compact">
        <view>
          <view class="panel-title">今日时间轴</view>
          <view class="panel-desc">按今天的实际执行顺序展示。</view>
        </view>
        <view class="count">{{todayTimeline.length}}步</view>
      </view>
      <view wx:for="{{todayTimeline}}" wx:key="time" class="timeline-row status-{{item.status}}">
        <view class="timeline-time">{{item.time}}</view>
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'task'}}" class="tab-page task-page">
    <view class="panel">
      <view class="panel-header">
        <view>
          <view class="panel-title">今日订单</view>
          <view class="panel-desc">今天要执行的订单，当前任务会同步到地图页。</view>
        </view>
        <view class="count">{{assignments.length}}单</view>
      </view>

      <view wx:if="{{assignments.length === 0}}" class="empty-state">今天没有订单。</view>
      <view wx:for="{{assignments}}" wx:key="assignment_id" class="order-row {{selected.assignment_id === item.assignment_id ? 'selected' : ''}}" data-id="{{item.assignment_id}}" bindtap="onSelectOrder">
        <view>
          <view class="order-time">{{item.datetime_label}}</view>
          <view class="order-route">{{item.pickup_location}} → {{item.dropoff_location}}</view>
        </view>
        <view class="badge-stack">
          <view class="flow-badge">{{item.day_flow_label}}</view>
          <view class="badge">{{item.status_label}}</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-header compact">
        <view>
          <view class="panel-title">明日订单</view>
          <view class="panel-desc">确认后明天到车库点呼出库。</view>
        </view>
        <view class="count">{{tomorrowAssignments.length}}单</view>
      </view>
      <view wx:if="{{tomorrowAssignments.length === 0}}" class="empty-state">暂无明日订单。</view>
      <view wx:for="{{tomorrowAssignments}}" wx:key="assignment_id" class="order-row" data-id="{{item.assignment_id}}" bindtap="onSelectOrder">
        <view>
          <view class="order-time">{{item.datetime_label}}</view>
          <view class="order-route">{{item.pickup_location}} → {{item.dropoff_location}}</view>
        </view>
        <view class="badge">{{item.status_label}}</view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-title">历史订单</view>
      <view wx:if="{{history.length === 0}}" class="empty-state">暂无履历。</view>
      <view wx:for="{{history}}" wx:key="id" wx:if="{{index < 6}}" class="history-row">
        <view>{{item.order_date}} {{item.start_time}} · {{item.pickup_location}} → {{item.dropoff_location}}</view>
        <view class="badge">{{item.execution_status || item.status || '-'}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'map'}}" class="tab-page map-page">
    <view class="map-shell">
      <map class="map-view" latitude="{{mapLatitude}}" longitude="{{mapLongitude}}" scale="{{mapScale}}" markers="{{mapMarkers}}" show-location="true"></map>
      <view wx:if="{{selected}}" class="map-current-card map-floating-card">
        <view class="section-label">当前订单</view>
        <view class="map-route-title">{{selected.pickup_location}} → {{selected.dropoff_location}}</view>
        <view class="map-route-meta">{{selected.datetime_label}} · {{selected.status_label}}</view>
        <view class="route-sub">客人：{{selected.guest_name || '-'}} · {{selected.guest_contact || '-'}}</view>
      </view>
    </view>

    <view class="panel photo-panel" wx:if="{{selected}}">
      <view class="panel-title">当前上传点</view>
      <view class="panel-desc">{{photoCollapsedText}}</view>
      <view wx:if="{{currentPhotoStep}}" class="photo-row current-photo {{currentPhotoStep.disabled ? 'locked' : ''}}">
        <view>
          <view>{{currentPhotoStep.label}}</view>
          <text wx:if="{{currentPhotoStep.location}}" class="lock-hint">{{currentPhotoStep.location}}</text>
          <text wx:if="{{currentPhotoStep.disabled}}" class="lock-hint">{{currentPhotoStep.hint}}</text>
        </view>
        <button disabled="{{currentPhotoStep.disabled}}" data-type="{{currentPhotoStep.key}}" bindtap="onPhotoTap">{{currentPhotoStep.disabled ? '未到达' : '拍照'}}</button>
      </view>
    </view>

  </view>

  <view wx:if="{{activeTab === 'expense'}}" class="tab-page">
    <view class="expense-actions compact-expenses">
      <view class="expense-entry" data-kind="advance" bindtap="openExpensePanel"><strong>垫付</strong><text>小票</text></view>
      <view class="expense-entry" data-kind="etc" bindtap="openExpensePanel"><strong>ETC</strong><text>高速</text></view>
      <view class="expense-entry" data-kind="parking" bindtap="openExpensePanel"><strong>停车</strong><text>停车费</text></view>
      <view class="expense-entry" data-kind="night" bindtap="openExpensePanel"><strong>夜班</strong><text>加班费</text></view>
      <view class="expense-entry collect" data-kind="collect" bindtap="openExpensePanel"><strong>代收</strong><text>现金</text></view>
    </view>

    <view wx:if="{{expensePanelOpen}}" class="panel">
      <view class="panel-header">
        <view class="panel-title">{{expenseKind === 'collect' ? '代收记录' : '垫付记录'}}</view>
        <button class="mini-button" bindtap="closeExpensePanel">收起</button>
      </view>
      <input class="field" type="number" placeholder="金额（日元）" value="{{expenseAmount}}" data-key="expenseAmount" bindinput="onInput" />
      <textarea class="textarea" placeholder="备注，例如停车费、高速费、座椅费" value="{{expenseNote}}" data-key="expenseNote" bindinput="onInput"></textarea>
      <button class="primary-button" bindtap="onSubmitExpense">提交费用</button>
    </view>

    <view class="panel">
      <view class="panel-title">费用记录</view>
      <view wx:if="{{expenses.length === 0}}" class="empty-state">暂无费用记录。</view>
      <view wx:for="{{expenses}}" wx:key="id" class="expense-row">
        <view><strong>{{item.category || item.expense_kind || '费用'}}</strong><text>{{item.note || '-'}}</text></view>
        <view class="amount">¥{{item.amount || 0}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'mine'}}" class="tab-page">
    <view class="profile-card">
      <view class="profile-avatar">{{driverInitial}}</view>
      <view>
        <view class="profile-name">{{driverName}}</view>
        <view class="profile-meta">司机ID {{driverId}} · {{isOnline ? '在线' : '离线'}}</view>
      </view>
    </view>

    <view class="metrics-grid calm">
      <view class="metric"><text>本月订单</text><strong>{{incomeSummary.monthly.order_count || 0}}</strong></view>
      <view class="metric"><text>本月收入</text><strong>¥{{incomeSummary.monthly.salary_amount || 0}}</strong></view>
    </view>

    <view class="panel">
      <view class="panel-title">证件提醒</view>
      <view class="profile-row"><text>驾照到期</text><strong>{{driverProfile.license_due_date || '-'}}</strong></view>
      <view class="profile-row"><text>健康体检</text><strong>{{driverProfile.health_check_due_date || '-'}}</strong></view>
      <view class="profile-row"><text>电话</text><strong>{{driverProfile.phone || '-'}}</strong></view>
    </view>

    <view class="panel">
      <view class="panel-title">设置</view>
      <view class="driver-switch">
        <input class="field" type="number" value="{{driverId}}" data-key="driverId" bindinput="onInput" />
        <button class="secondary-button" bindtap="onSwitchDriver">切换</button>
      </view>
    </view>
  </view>

  <view class="bottom-tabs">
    <view wx:for="{{tabItems}}" wx:key="key" class="bottom-tab {{activeTab === item.key ? 'active' : ''}}" data-tab="{{item.key}}" catchtap="onTabChange">
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{dockVisible}}" class="primary-dock">
    <button class="primary-button dock-button" disabled="{{submitting || dockDisabled}}" bindtap="onPrimaryAction">
      {{submitting ? '提交中...' : dockLabel}}
    </button>
  </view>
</view>
