@import "../../styles/theme.wxss";

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 20rpx 206rpx;
  background: #eef3f8;
  color: #0f172a;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 400;
}

.driver-login {
  min-height: calc(100vh - 226rpx);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.login-hero {
  overflow: hidden;
  position: relative;
  padding: 34rpx 32rpx;
  border-radius: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #07111f 0%, #123e78 58%, #2563eb 100%);
  box-shadow: 0 22rpx 46rpx rgba(15, 23, 42, 0.18);
}

.login-hero::after {
  content: "";
  position: absolute;
  right: -48rpx;
  top: -60rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.login-eyebrow {
  font-size: 21rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.72);
}

.login-title {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 46rpx;
  font-weight: 900;
}

.login-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-card {
  padding: 30rpx;
  border: 1rpx solid #dce5ef;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.login-label {
  margin: 16rpx 0 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #334155;
}

.login-input {
  height: 84rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 1rpx solid #d9e3ef;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.login-button {
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 22rpx;
  background: #16a34a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 32rpx rgba(22, 163, 74, 0.22);
}

.login-error {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fef2f2;
  color: #dc2626;
  font-size: 24rpx;
  font-weight: 800;
}

.login-help {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.logout-button {
  width: 100%;
  margin-bottom: 22rpx;
}

.driver-hero {
  position: sticky;
  top: 0;
  z-index: 10;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #07111f 0%, #123e78 58%, #1d4ed8 100%);
  box-shadow: 0 22rpx 46rpx rgba(15, 23, 42, 0.2);
}

.driver-hero::after {
  content: "";
  position: absolute;
  right: -48rpx;
  top: -64rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
}

.task-page {
  padding-top: 0;
}

.status-departed {
  background: linear-gradient(135deg, #07111f 0%, #123e78 58%, #1d4ed8 100%);
}

.status-rest {
  background: linear-gradient(135deg, #07111f 0%, #102a55 100%);
}

.hero-top,
.panel-header,
.order-row,
.expense-row,
.history-row,
.profile-row,
.driver-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-main {
  position: relative;
  z-index: 1;
  min-width: 0;
  text-align: left;
}

.driver-name {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.driver-meta {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  font-weight: 500;
}

.status-pill {
  position: relative;
  z-index: 1;
  flex: none;
  min-width: 108rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.status-ready .status-pill {
  color: #bfdbfe;
}

.status-departed .status-pill {
  color: #ffffff;
  background: rgba(22, 163, 74, 0.28);
}

.status-rest .status-pill {
  color: #e2e8f0;
}

.hero-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.3fr 0.8fr 0.9fr;
  gap: 10rpx;
  margin-top: 24rpx;
}

.hero-grid view {
  min-width: 0;
  padding: 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
}

.hero-grid text,
.metric text,
.yard-grid text {
  display: block;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 500;
}

.hero-grid text {
  color: rgba(255, 255, 255, 0.7);
}

.hero-grid strong,
.metric strong,
.yard-grid strong {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.12;
}

.tab-page {
  display: block;
}

.home-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.metrics-grid,
.yard-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.mine-stats {
  grid-template-columns: repeat(3, 1fr);
}

.yard-grid {
  grid-template-columns: repeat(3, 1fr);
}

.metric,
.yard-grid view,
.panel,
.task-card,
.expense-entry,
.map-current-card,
.map-shell {
  border: 1rpx solid #dce5ef;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.metric,
.yard-grid view {
  min-height: 98rpx;
  box-sizing: border-box;
  padding: 16rpx;
}

.metric.warn {
  border-color: #fed7aa;
  background: #fff7ed;
}

.metric strong {
  color: #0f172a;
  font-size: 34rpx;
}

.panel,
.task-card,
.map-current-card,
.map-shell {
  box-sizing: border-box;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.primary-task {
  border-color: #bfdbfe;
  background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
}

.confirm-card {
  box-sizing: border-box;
  margin-bottom: 16rpx;
  padding: 26rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.09);
}

.focus-panel {
  border-color: #bfdbfe;
  background: #ffffff;
}

.focus-route,
.focus-empty {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fbff;
}

.focus-time {
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 850;
}

.focus-title {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.24;
}

.focus-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 500;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.status-strip view {
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #dce5ef;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.status-strip text {
  display: block;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
}

.status-strip strong {
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 900;
}

.timeline-panel {
  padding-bottom: 14rpx;
}

.yard-panel.folded {
  border-color: #e2e8f0;
  background: #f8fafc;
}

.folded-note {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #475569;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 650;
}

.panel-header.compact {
  align-items: flex-start;
}

.timeline-row {
  display: grid;
  grid-template-columns: 76rpx 24rpx 1fr;
  gap: 12rpx;
  align-items: flex-start;
  padding: 16rpx 0;
}

.timeline-row + .timeline-row {
  border-top: 1rpx solid #edf2f7;
}

.timeline-time {
  padding-top: 2rpx;
  color: #1e293b;
  font-size: 24rpx;
  font-weight: 900;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: #93c5fd;
  box-shadow: 0 0 0 8rpx #eff6ff;
}

.timeline-row.status-completed .timeline-dot,
.timeline-row.status-return .timeline-dot {
  background: #16a34a;
  box-shadow: 0 0 0 8rpx #dcfce7;
}

.timeline-row.status-yard .timeline-dot {
  background: #f59e0b;
  box-shadow: 0 0 0 8rpx #fef3c7;
}

.timeline-title {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.3;
}

.timeline-meta {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.confirm-eyebrow {
  color: #1e3a8a;
  font-size: 24rpx;
  font-weight: 800;
}

.confirm-headline {
  margin-top: 8rpx;
  color: #020617;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.confirm-preview {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.confirm-preview + .confirm-preview {
  margin-top: 10rpx;
}

.confirm-route {
  color: #020617;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.35;
}

.confirm-guest {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 500;
}

.confirm-more {
  margin-top: 14rpx;
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 700;
}

.confirm-all-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: #16a34a;
  font-size: 31rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 34rpx rgba(22, 163, 74, 0.24);
}

.panel-title {
  font-size: 30rpx;
  font-weight: 850;
}

.panel-desc,
.section-label,
.task-hint,
.route-sub,
.empty-state {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 400;
}

.count {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #1d4ed8;
  background: #eff6ff;
  font-size: 22rpx;
  font-weight: 800;
}

.next-action {
  margin-top: 10rpx;
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.14;
}

.task-hint {
  margin-top: 8rpx;
  line-height: 1.5;
}

.route-box {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.82);
}

.route-time,
.order-time {
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 800;
}

.route-main,
.order-route {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.order-row {
  margin-top: 12rpx;
  padding: 15rpx 16rpx;
  border: 1rpx solid #e3eaf4;
  border-radius: 18rpx;
  background: #ffffff;
}

.order-row.selected {
  border-color: #2563eb;
  background: #eff6ff;
}

.badge,
.confirm-badge,
.flow-badge {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge {
  color: #1d4ed8;
  background: #eff6ff;
}

.confirm-badge {
  color: #ffffff;
  background: #2563eb;
}

.flow-badge {
  color: #065f46;
  background: #dcfce7;
}

.badge-stack {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 66rpx;
  font-size: 27rpx;
  font-weight: 600;
}

.check-dot {
  flex: none;
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #94a3b8;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.check-dot.checked {
  border-color: #16a34a;
  background: #16a34a;
}

.map-page {
  margin-left: -18rpx;
  margin-right: -18rpx;
  margin-top: 0;
}

.map-current-card {
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  background: rgba(15, 23, 42, 0.84);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.28);
}

.map-floating-card {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 18rpx;
  z-index: 3;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 22rpx;
  color: #ffffff;
}

.map-route-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.18;
}

.map-route-meta {
  margin-top: 8rpx;
  color: #93c5fd;
  font-size: 24rpx;
  font-weight: 800;
}

.map-floating-card .section-label,
.map-floating-card .route-sub {
  color: rgba(255, 255, 255, 0.78);
}

.map-shell {
  position: relative;
  overflow: hidden;
  margin-left: 18rpx;
  margin-right: 18rpx;
  padding: 0;
  border: 0;
  border-radius: 30rpx;
  background: #0f172a;
  box-shadow: 0 20rpx 54rpx rgba(15, 23, 42, 0.18);
}

.map-view {
  width: 100%;
  height: 980rpx;
  display: block;
}

.secondary-button,
.primary-button,
.photo-row button,
.mini-button {
  min-height: 74rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.secondary-button {
  color: #1d4ed8;
  background: #eef4ff;
}

.calendar-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.date-picker,
.mode-button,
.month-button {
  min-height: 64rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  line-height: 64rpx;
  text-align: center;
  font-weight: 800;
}

.date-picker {
  min-width: 190rpx;
  padding: 0 18rpx;
  color: #1d4ed8;
  background: #eef4ff;
}

.mode-button {
  width: 64rpx;
  padding: 0;
  color: #ffffff;
  background: #1d4ed8;
}

.month-bar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.month-button {
  padding: 0;
  color: #1d4ed8;
  background: #eef4ff;
  font-size: 34rpx;
}

.month-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
}

.weekday-row,
.month-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.weekday-row {
  margin-top: 16rpx;
  color: #64748b;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
}

.weekday-row view {
  padding: 8rpx 0;
}

.month-grid {
  gap: 8rpx;
}

.day-cell {
  position: relative;
  min-height: 82rpx;
  box-sizing: border-box;
  padding: 10rpx 8rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #ffffff;
}

.month-grid.week-mode .day-cell {
  min-height: 104rpx;
}

.day-cell.blank {
  border-color: transparent;
  background: transparent;
}

.day-cell.today {
  border-color: #93c5fd;
  background: #eff6ff;
}

.day-cell.active {
  border-color: #1d4ed8;
  background: #dbeafe;
  box-shadow: inset 0 0 0 2rpx #1d4ed8;
}

.day-cell.holiday .day-number,
.holiday-name {
  color: #dc2626;
}

.day-number {
  font-size: 24rpx;
  font-weight: 800;
}

.holiday-name {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  max-width: 72rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 16rpx;
  font-weight: 700;
}

.day-count {
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  min-width: 42rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #1d4ed8;
  font-size: 18rpx;
  font-weight: 800;
  text-align: center;
}

.photo-row {
  display: grid;
  grid-template-columns: 1fr 126rpx;
  gap: 12rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #e3eaf4;
  border-radius: 18rpx;
  background: #fbfdff;
}

.current-photo {
  border-color: #bfdbfe;
  background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
}

.photo-row button {
  color: #1d4ed8;
  background: #eef4ff;
}

.photo-row.locked {
  color: #94a3b8;
  background: #f8fafc;
}

.photo-row.locked button {
  color: #94a3b8;
  background: #e2e8f0;
}

.lock-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.expense-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.compact-expenses {
  grid-template-columns: repeat(5, 1fr);
}

.expense-entry {
  min-height: 112rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
}

.expense-entry.collect {
  border-color: #bbf7d0;
  background: linear-gradient(180deg, #ffffff 0%, #ecfdf5 100%);
}

.expense-entry strong {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
}

.compact-expenses .expense-entry {
  min-height: 94rpx;
  padding: 14rpx 10rpx;
  text-align: center;
}

.compact-expenses .expense-entry strong {
  font-size: 26rpx;
}

.compact-expenses .expense-entry text {
  font-size: 20rpx;
}

.expense-entry text,
.expense-row text {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
}

.field,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d8e1ef;
  border-radius: 18rpx;
  background: #ffffff;
  font-size: 25rpx;
}

.field {
  min-height: 76rpx;
  padding: 0 18rpx;
  margin-top: 12rpx;
  line-height: 76rpx;
}

.textarea {
  min-height: 120rpx;
  padding: 16rpx 18rpx;
  margin-top: 12rpx;
}

.primary-button {
  margin-top: 18rpx;
  color: #ffffff;
  background: #16a34a;
  box-shadow: 0 16rpx 34rpx rgba(22, 163, 74, 0.24);
}

.expense-row,
.history-row {
  margin-top: 12rpx;
  padding: 16rpx;
  border: 1rpx solid #e3eaf4;
  border-radius: 18rpx;
  background: #fbfdff;
}

.amount {
  flex: none;
  font-weight: 800;
}

.driver-switch .field {
  flex: 1;
}

.driver-switch .secondary-button {
  width: 160rpx;
  margin-top: 12rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  margin-bottom: 14rpx;
  padding: 22rpx;
  border: 1rpx solid #dce5ef;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.profile-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
  font-size: 34rpx;
  font-weight: 900;
}

.profile-name {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
}

.contact-panel {
  padding-bottom: 26rpx;
}

.contact-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.field-group text {
  display: block;
  margin-bottom: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 700;
}

.save-contact-button {
  width: 100%;
  margin-top: 18rpx;
  min-height: 78rpx;
  border-radius: 20rpx;
}

.metrics-grid.calm {
  grid-template-columns: repeat(2, 1fr);
}

.loading,
.empty-state {
  text-align: center;
}

.bottom-tabs {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 16rpx;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0;
  height: 88rpx;
  box-sizing: border-box;
  padding: 8rpx calc(8rpx + env(safe-area-inset-right)) calc(8rpx + env(safe-area-inset-bottom)) calc(8rpx + env(safe-area-inset-left));
  border: 1rpx solid #dce4ef;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 34rpx rgba(30, 54, 92, 0.12);
}

.bottom-tab {
  min-height: 0;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #6b7890;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.bottom-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.24);
}

.primary-dock {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 118rpx;
  z-index: 19;
}

.dock-button {
  width: 100%;
  min-height: 96rpx;
  margin-top: 0;
  border-radius: 26rpx;
  font-size: 30rpx;
  font-weight: 900;
}

button[disabled] {
  color: #64748b;
  background: #e2e8f0;
  box-shadow: none;
  opacity: 1;
}

button::after {
  border: 0;
}
