.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 20rpx 28rpx;
  background: #f3f6fb;
  color: #0f172a;
}

.top-status {
  position: sticky;
  top: 0;
  z-index: 6;
  border-radius: 22rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f2a66 0%, #1d4ed8 100%);
}

.status-ready {
  background: linear-gradient(135deg, #0f2a66 0%, #1d4ed8 100%);
}

.status-departed {
  background: linear-gradient(135deg, #0f5132 0%, #16a34a 100%);
}

.status-rest {
  background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
}

.top-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.driver {
  font-size: 34rpx;
  font-weight: 800;
}

.state-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  font-weight: 700;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.offline {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #fee2e2;
}

.month-kpi {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.kpi-item {
  border: 1rpx solid #d7e0ee;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 14rpx;
}

.kpi-item text {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.kpi-item strong {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.driver-switch {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.tab {
  min-height: 64rpx;
  border-radius: 14rpx;
  background: #e8eef9;
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
}

.tab.on {
  background: #1d4ed8;
  color: #ffffff;
}

.card {
  border: 1rpx solid #d8e1ee;
  border-radius: 18rpx;
  background: #ffffff;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 27rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.hint {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.check-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #94a3b8;
}

.check-dot.on {
  border-color: #16a34a;
  background: #16a34a;
}

.check-label {
  font-size: 25rpx;
}

.next-label {
  margin-top: 2rpx;
  font-size: 36rpx;
  font-weight: 800;
}

.btn {
  min-height: 68rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.btn.light {
  color: #1d4ed8;
  background: #eef4ff;
}

.btn.primary {
  color: #ffffff;
  background: #16a34a;
}

.btn.big {
  margin-top: 12rpx;
  min-height: 94rpx;
  font-size: 34rpx;
}

.order-row,
.photo-row {
  margin-top: 10rpx;
  border: 1rpx solid #e1e8f3;
  border-radius: 14rpx;
  background: #f9fbff;
  padding: 12rpx;
}

.order-row.active {
  border-color: #1d4ed8;
  background: #e7efff;
}

.muted,
.row-meta {
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.45;
}

.order-id {
  font-size: 24rpx;
  font-weight: 700;
}

.route {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.order-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 12rpx;
}

.folded {
  border-style: dashed;
}

.map-preview {
  width: 100%;
  height: 260rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin: 10rpx 0;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d8e1ef;
  border-radius: 14rpx;
  background: #ffffff;
  font-size: 24rpx;
}

.input {
  min-height: 70rpx;
  padding: 0 16rpx;
  margin-top: 10rpx;
}

.textarea {
  min-height: 110rpx;
  padding: 14rpx 16rpx;
  margin-top: 10rpx;
}

.photo-step {
  margin-top: 10rpx;
  border: 1rpx solid #e2e8f4;
  border-radius: 14rpx;
  padding: 12rpx;
  display: grid;
  grid-template-columns: 1fr 112rpx;
  gap: 10rpx;
  align-items: center;
}

.step-title {
  font-size: 26rpx;
  font-weight: 700;
}
