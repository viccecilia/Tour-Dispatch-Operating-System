@import "../../styles/theme.wxss";

.page {
  min-height: 100vh;
  background: var(--c-bg);
  padding: 24rpx;
  color: var(--c-text);
}

.section {
  padding: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.state,
.message {
  padding: 22rpx;
  text-align: center;
  color: #5b6472;
}

.order-row,
.assigned-row {
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.selected {
  border-color: #1f2933;
  background: #f1f5f9;
}

.assigned-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.assigned-main {
  flex: 1;
}

.line {
  font-size: 24rpx;
  line-height: 1.55;
  word-break: break-all;
}

.strong {
  font-weight: 700;
}

.muted {
  color: #5b6472;
}

.picker-cell {
  min-height: 76rpx;
  line-height: 76rpx;
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-control);
  padding: 0 18rpx;
  margin-bottom: 14rpx;
}

.primary,
.danger {
  border-radius: var(--r-control);
  font-size: 26rpx;
}

.primary {
  background: var(--c-primary);
  color: #ffffff;
}

.danger {
  width: 120rpx;
  background: #fff1f2;
  color: #be123c;
}

.warning {
  border-color: #f59e0b;
  background: #fffbeb;
}
