.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 32rpx;
  color: #20242a;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5b6472;
  font-size: 26rpx;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.metric {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 24rpx;
}

.label {
  display: block;
  color: #5b6472;
  font-size: 24rpx;
}

.value {
  display: block;
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.nav {
  margin-top: 30rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.nav-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #edf0f3;
}

.nav-item:last-child {
  border-bottom: 0;
}

.nav-arrow {
  color: #5b6472;
  font-size: 24rpx;
}
