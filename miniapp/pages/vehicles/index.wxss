.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 24rpx;
  color: #20242a;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5b6472;
  font-size: 24rpx;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.input,
.picker {
  min-height: 72rpx;
  line-height: 72rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  background: #ffffff;
}

.primary,
.secondary {
  margin: 0;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.primary {
  background: #1f2933;
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #20242a;
}

.full {
  width: 100%;
  margin-bottom: 14rpx;
}

.row {
  display: flex;
  gap: 10rpx;
  align-items: center;
  border-top: 1rpx solid #edf0f3;
  padding: 16rpx 0;
}

.main {
  flex: 1;
  min-width: 0;
}

.strong,
.muted {
  display: block;
  line-height: 1.5;
  word-break: break-all;
}

.strong {
  font-size: 26rpx;
  font-weight: 700;
}

.muted {
  color: #5b6472;
  font-size: 23rpx;
}

.state {
  padding: 36rpx 0;
  color: #5b6472;
  text-align: center;
}

.error {
  color: #be123c;
}
