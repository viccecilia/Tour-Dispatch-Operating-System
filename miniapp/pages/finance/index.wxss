.page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 24rpx;
  color: #20242a;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5b6472;
  font-size: 24rpx;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.metric,
.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.metric {
  padding: 20rpx;
}

.label {
  display: block;
  color: #5b6472;
  font-size: 23rpx;
}

.value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.section {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-top: 1rpx solid #edf0f3;
  padding: 16rpx 0;
}

.main {
  flex: 1;
  min-width: 0;
}

.strong,
.muted {
  display: block;
  line-height: 1.5;
  word-break: break-all;
}

.strong {
  font-size: 25rpx;
  font-weight: 700;
}

.muted {
  color: #5b6472;
  font-size: 23rpx;
}

.amount {
  font-size: 25rpx;
  font-weight: 700;
}

.state {
  padding: 36rpx 0;
  color: #5b6472;
  text-align: center;
}

.error {
  color: #be123c;
}
