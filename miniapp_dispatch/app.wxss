page {
  min-height: 100vh;
  --c-primary: #246bfe;
  --c-primary-dark: #1748c7;
  --c-primary-soft: #edf4ff;
  --c-success: #16a34a;
  --c-success-soft: #e9f9ef;
  --c-warning: #f59e0b;
  --c-warning-soft: #fff7e6;
  --c-danger: #ef4444;
  --c-danger-soft: #fff1f2;
  --c-info: #0891b2;
  --c-info-soft: #eaf8fb;
  --c-bg: #f4f7fb;
  --c-card: #ffffff;
  --c-surface-soft: #f8fbff;
  --c-border: #e3eaf3;
  --c-text: #102033;
  --c-muted: #718096;
  --r-card: 28rpx;
  --r-panel: 32rpx;
  --r-control: 22rpx;
  --shadow-card: 0 12rpx 30rpx rgba(30, 54, 92, 0.07);
  --shadow-float: 0 20rpx 50rpx rgba(30, 54, 92, 0.12);
  --fs-title: 42rpx;
  --fs-section: 31rpx;
  --fs-card: 27rpx;
  --fs-body: 25rpx;
  --fs-muted: 22rpx;
  background: var(--c-bg);
  color: var(--c-text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 32rpx;
  color: #fff;
  background: linear-gradient(135deg, #153b92 0%, #246bfe 100%);
  box-shadow: var(--shadow-float);
}

.hero::after {
  content: "";
  position: absolute;
  right: -36rpx;
  top: -42rpx;
  width: 170rpx;
  height: 170rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.hero-eyebrow {
  font-size: 21rpx;
  opacity: 0.78;
  font-weight: 900;
}

.hero-title {
  margin-top: 10rpx;
  font-size: var(--fs-title);
  font-weight: 950;
  letter-spacing: 0;
}

.hero-meta {
  margin-top: 10rpx;
  font-size: var(--fs-body);
  line-height: 1.35;
  opacity: 0.86;
}

.panel {
  margin-top: 20rpx;
  border-radius: var(--r-panel);
  padding: 24rpx;
  background: var(--c-card);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.panel-title {
  color: var(--c-text);
  font-size: var(--fs-section);
  font-weight: 950;
}

.muted {
  color: var(--c-muted);
  font-size: var(--fs-muted);
  line-height: 1.4;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric {
  border-radius: var(--r-card);
  padding: 20rpx;
  background: var(--c-surface-soft);
  border: 1rpx solid var(--c-border);
  box-shadow: 0 8rpx 22rpx rgba(30, 54, 92, 0.04);
}

.metric text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 750;
}

.metric strong {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: 39rpx;
  font-weight: 950;
}

.button-primary,
.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  margin: 0;
}

.button-primary {
  height: 92rpx;
  border-radius: var(--r-control);
  background: var(--c-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(36, 107, 254, 0.22);
}

.button-secondary {
  height: 78rpx;
  border-radius: var(--r-control);
  background: var(--c-primary-soft);
  color: var(--c-primary-dark);
  font-size: 26rpx;
  font-weight: 850;
}

.button-primary::after,
.button-secondary::after {
  border: 0;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-control);
  background: var(--c-surface-soft);
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--c-text);
}

.textarea {
  min-height: 260rpx;
}

.list {
  margin-top: 18rpx;
}

.row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.row:last-child {
  border-bottom: 0;
}

.row-title {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 850;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  background: var(--c-primary-soft);
  color: var(--c-primary-dark);
  font-size: 22rpx;
  font-weight: 850;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-state,
.loading-state,
.error-state {
  box-sizing: border-box;
  padding: 30rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: var(--r-panel);
  background: var(--c-card);
  color: var(--c-muted);
  text-align: center;
  font-size: var(--fs-body);
}
