page {
  min-height: 100vh;
  background: #eef3f8;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 22rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  padding: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #07111f 0%, #123e78 56%, #1d4ed8 100%);
  box-shadow: 0 22rpx 48rpx rgba(15, 23, 42, 0.18);
}

.hero::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -52rpx;
  width: 168rpx;
  height: 168rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.13);
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.76;
  font-weight: 850;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.82;
}

.panel {
  margin-top: 20rpx;
  border-radius: 26rpx;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #dbe5f0;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.065);
}

.panel-title {
  font-size: 30rpx;
  font-weight: 900;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric {
  border-radius: 20rpx;
  padding: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.metric text {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.metric strong {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 24rpx;
  background: #1d4ed8;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  border: 0;
}

.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 20rpx;
  background: #eef4ff;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid #c7d7fe;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #dbe5f0;
  border-radius: 22rpx;
  background: #f8fafc;
  padding: 20rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.textarea {
  min-height: 260rpx;
}

.list {
  margin-top: 18rpx;
}

.row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.row-title {
  font-size: 27rpx;
  font-weight: 750;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
