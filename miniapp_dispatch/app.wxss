page {
  min-height: 100vh;
  --c-primary: #2563eb;
  --c-primary-soft: #eff6ff;
  --c-success: #169456;
  --c-success-soft: #ecfdf5;
  --c-warning: #f59e0b;
  --c-warning-soft: #fffbeb;
  --c-danger: #dc2626;
  --c-danger-soft: #fef2f2;
  --c-info: #0891b2;
  --c-info-soft: #ecfeff;
  --c-bg: #eef3f8;
  --c-card: #ffffff;
  --c-surface-soft: #f8fafc;
  --c-border: #dbe5f0;
  --c-text: #0f172a;
  --c-muted: #64748b;
  --r-card: 24rpx;
  --r-panel: 28rpx;
  --r-control: 20rpx;
  --shadow-card: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
  --shadow-runtime: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
  --fs-title: 42rpx;
  --fs-section: 30rpx;
  --fs-card: 27rpx;
  --fs-body: 25rpx;
  --fs-muted: 22rpx;
  background: var(--c-bg);
  color: var(--c-text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 22rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 58%, var(--c-primary) 100%);
  box-shadow: var(--shadow-runtime);
}

.hero::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -52rpx;
  width: 168rpx;
  height: 168rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.13);
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.76;
  font-weight: 850;
}

.hero-title {
  margin-top: 8rpx;
  font-size: var(--fs-title);
  font-weight: 900;
  letter-spacing: 0;
}

.hero-meta {
  margin-top: 10rpx;
  font-size: var(--fs-body);
  opacity: 0.82;
}

.panel {
  margin-top: 20rpx;
  border-radius: var(--r-panel);
  padding: 24rpx;
  background: var(--c-card);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  transition: transform 120ms ease, box-shadow 160ms ease, background-color 160ms ease;
}

.panel:active,
.metric:active,
.row:active {
  transform: scale(0.992);
}

.panel-title {
  font-size: var(--fs-section);
  font-weight: 900;
}

.muted {
  color: var(--c-muted);
  font-size: var(--fs-muted);
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric {
  border-radius: var(--r-card);
  padding: 20rpx;
  background: var(--c-surface-soft);
  border: 1rpx solid #e2e8f0;
}

.metric text {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.metric strong {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: var(--r-control);
  background: var(--c-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  border: 0;
  transition: transform 120ms ease, opacity 120ms ease;
}

.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: var(--r-control);
  background: var(--c-primary-soft);
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid #c7d7fe;
  transition: transform 120ms ease, opacity 120ms ease;
}

.button-primary:active,
.button-secondary:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #dbe5f0;
  border-radius: var(--r-control);
  background: var(--c-surface-soft);
  padding: 20rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.textarea {
  min-height: 260rpx;
}

.list {
  margin-top: 18rpx;
}

.row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.row-title {
  font-size: 27rpx;
  font-weight: 750;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  background: var(--c-primary-soft);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-state,
.loading-state,
.error-state {
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: var(--r-panel);
  background: var(--c-card);
  color: var(--c-muted);
  text-align: center;
  font-size: var(--fs-body);
}

.skeleton-line {
  position: relative;
  overflow: hidden;
  height: 22rpx;
  border-radius: 999rpx;
  background: #eef3f8;
}

.skeleton-line::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.72), transparent);
  animation: skeleton-shimmer 1.45s infinite;
}

@keyframes skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}
