<view class="page">
  <view class="hero finance-hero">
    <view class="hero-eyebrow">MOBILE FINANCE</view>
    <view class="hero-title">财务概览</view>
    <view class="hero-meta">订单金额、司机垫付、代收款和待确认费用。</view>
  </view>

  <view class="panel finance-overview">
    <view class="panel-title">今日财务待办</view>
    <view class="finance-focus-grid">
      <view class="finance-focus">
        <text>今日金额</text>
        <strong>¥{{summary.today_amount || 0}}</strong>
      </view>
      <view class="finance-focus warning">
        <text>待确认费用</text>
        <strong>¥{{summary.pending_amount || 0}}</strong>
      </view>
      <view class="finance-focus">
        <text>司机垫付</text>
        <strong>¥{{summary.driver_advance_total || 0}}</strong>
      </view>
      <view class="finance-focus success">
        <text>司机代收</text>
        <strong>¥{{summary.driver_collect_total || 0}}</strong>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">订单金额</view>
    <view class="grid finance-sub-grid">
      <view class="metric"><text>订单数</text><strong>{{summary.order_count || 0}}</strong></view>
      <view class="metric"><text>合计金额</text><strong>¥{{summary.total_amount || 0}}</strong></view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">费用记录流</view>
    <view class="finance-list">
      <view wx:for="{{orders}}" wx:key="order_id" class="finance-row">
        <view>
          <view class="row-title">{{item.oid || item.order_id}} · {{item.agency_name || '未填旅行社'}}</view>
          <view class="muted">{{item.order_date}} {{item.start_time || ''}} · {{item.driver_name || '未派司机'}}</view>
        </view>
        <view class="amount">¥{{item.price || 0}}</view>
      </view>
      <view wx:if="{{!orders.length}}" class="empty-state">
        <view class="empty-title">暂无财务订单</view>
        <view class="muted">派车或完成订单后，这里会出现费用记录。</view>
      </view>
    </view>
  </view>

  <view wx:if="{{message}}" class="panel muted">{{message}}</view>
</view>
