@import "../../app.wxss";

.finance-hero {
  background: linear-gradient(135deg, #312e81, #7c3aed);
}

.finance-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.finance-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.amount {
  flex: 0 0 auto;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 950;
}
