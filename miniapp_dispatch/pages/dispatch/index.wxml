<view class="page dispatch-page">
  <view class="hero quick-hero">
    <view>
      <view class="hero-eyebrow">MOBILE QUICK DISPATCH</view>
      <view class="hero-title">3 秒派车</view>
      <view class="hero-meta">接机 / 送机 / 包车 -> 司机 -> 车辆 -> 一键派发</view>
    </view>
    <view class="hero-count">
      <text>已选</text>
      <strong>{{selectedOrderIds.length}}</strong>
    </view>
  </view>

  <view wx:if="{{conflictText}}" class="conflict">{{conflictText}}</view>
  <view wx:elif="{{message}}" class="success-text">{{message}}</view>

  <view class="panel work-box charter-box">
    <view class="box-head">
      <view>
        <view class="panel-title">包车</view>
        <view class="muted">内容较多，横向表格查看，按时间排序</view>
      </view>
      <text class="soft-badge purple">{{charterOrders.length}} 单</text>
    </view>
    <scroll-view scroll-y class="charter-scroll">
      <view class="charter-head">
        <text>时间</text>
        <text>路线</text>
        <text>车型</text>
        <text>价格</text>
      </view>
      <view
        wx:for="{{charterOrders}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="toggleOrder"
        class="charter-row {{item.selected ? 'selected' : ''}}"
      >
        <text>{{item.timeText}}</text>
        <text class="route-cell">{{item.routeText}}</text>
        <text>{{item.vehicle_type || '车型'}}</text>
        <text>JPY{{item.price || 0}}</text>
      </view>
      <view wx:if="{{!charterOrders.length}}" class="muted empty-line">暂无包车订单。</view>
    </scroll-view>
  </view>

  <view class="airport-grid">
    <view class="panel work-box order-box">
      <view class="box-head">
        <view>
          <view class="panel-title">接机</view>
          <view class="muted">机场出发，按时间排序</view>
        </view>
        <text class="soft-badge">{{pickupOrders.length}} 单</text>
      </view>
      <scroll-view scroll-y class="box-scroll">
        <view
          wx:for="{{pickupOrders}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="toggleOrder"
          class="order-row {{item.selected ? 'selected' : ''}}"
        >
          <view class="order-time">{{item.timeText}}</view>
          <view class="order-route">{{item.routeText}}</view>
          <view class="order-side">
            <text>{{item.vehicle_type || '车型'}}</text>
            <strong>JPY{{item.price || 0}}</strong>
          </view>
        </view>
        <view wx:if="{{!pickupOrders.length}}" class="muted empty-line">暂无接机订单。</view>
      </scroll-view>
    </view>

    <view class="panel work-box order-box">
      <view class="box-head">
        <view>
          <view class="panel-title">送机</view>
          <view class="muted">目的地机场，按时间排序</view>
        </view>
        <text class="soft-badge warn">{{dropoffOrders.length}} 单</text>
      </view>
      <scroll-view scroll-y class="box-scroll">
        <view
          wx:for="{{dropoffOrders}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="toggleOrder"
          class="order-row {{item.selected ? 'selected' : ''}}"
        >
          <view class="order-time">{{item.timeText}}</view>
          <view class="order-route">{{item.routeText}}</view>
          <view class="order-side">
            <text>{{item.vehicle_type || '车型'}}</text>
            <strong>JPY{{item.price || 0}}</strong>
          </view>
        </view>
        <view wx:if="{{!dropoffOrders.length}}" class="muted empty-line">暂无送机订单。</view>
      </scroll-view>
    </view>

  </view>

  <view class="resource-grid">
    <view class="panel work-box resource-box">
      <view class="box-head">
        <view>
          <view class="panel-title">司机</view>
          <view class="muted">空闲优先，冲突靠后</view>
        </view>
      </view>
      <scroll-view scroll-y class="box-scroll resource-scroll">
        <view
          wx:for="{{drivers}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectDriver"
          class="mini-resource {{item.selected ? 'selected' : ''}}"
        >
          <view class="mini-name">{{item.name}}</view>
          <view class="mini-status {{item.statusClass}}">{{item.availabilityText}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="panel work-box resource-box">
      <view class="box-head">
        <view>
          <view class="panel-title">车辆</view>
          <view class="muted">空闲优先，冲突靠后</view>
        </view>
      </view>
      <scroll-view scroll-y class="box-scroll resource-scroll">
        <view
          wx:for="{{vehicles}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectVehicle"
          class="mini-resource {{item.selected ? 'selected' : ''}}"
        >
          <view class="mini-name">{{item.shortPlate || item.plate_number}}</view>
          <view class="mini-status {{item.statusClass}}">{{item.availabilityText}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="dispatch-preview">
    <view class="preview-summary">
      <view class="preview-title">{{preview.orders}} 单待派</view>
      <view class="preview-sub">司机：{{preview.driver}} · 车辆：{{preview.vehicle}}</view>
    </view>
    <button
      class="dispatch-button {{canAssign ? 'ready' : 'disabled'}}"
      loading="{{loading}}"
      disabled="{{!canAssign || loading}}"
      bindtap="assign"
    >
      {{assignButtonText}}
    </button>
  </view>
</view>
