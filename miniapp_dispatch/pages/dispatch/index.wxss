@import "../../app.wxss";

.dispatch-page {
  padding-bottom: 190rpx;
}

.quick-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-count {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 96rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.18);
  color: #dbeafe;
  font-size: 20rpx;
  font-weight: 800;
}

.hero-count strong {
  color: #ffffff;
  font-size: 38rpx;
  line-height: 1;
}

.toolbar {
  display: grid;
  grid-template-columns: 1.15fr 1fr 0.75fr;
  gap: 12rpx;
  margin: 16rpx 0;
}

.tool-button {
  height: 72rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--c-border);
  color: var(--c-text);
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: var(--shadow-card);
}

.tool-button.primary {
  color: #ffffff;
  border-color: var(--c-primary);
  background: var(--c-primary);
}

.tool-button::after,
.button-primary::after,
.mini-btn::after,
.small-button::after,
.dispatch-button::after {
  border: 0;
}

.import-panel,
.charter-panel,
.resource-box {
  margin-top: 14rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.section-head.small {
  align-items: flex-start;
}

.count-pill {
  flex: 0 0 auto;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  color: var(--c-primary);
  background: var(--c-primary-soft);
  font-size: 20rpx;
  font-weight: 900;
}

.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--c-border);
  color: var(--c-text);
  background: #f8fafc;
  font-size: 25rpx;
  line-height: 1.45;
}

.button-primary {
  height: 78rpx;
  margin-top: 14rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: var(--c-primary);
  font-size: 28rpx;
  font-weight: 900;
}

.charter-scroll {
  height: 276rpx;
  margin-top: 12rpx;
}

.airport-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.list-panel {
  min-width: 0;
  padding: 18rpx;
}

.airport-scroll {
  height: 478rpx;
  margin-top: 10rpx;
}

.compact-row {
  min-height: 86rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
  padding: 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--c-border);
  background: #ffffff;
}

.charter-row {
  min-height: 76rpx;
}

.compact-row.selected {
  border-color: var(--c-primary);
  background: #f5f9ff;
}

.compact-row.risk {
  border-color: #fed7aa;
}

.status-dot {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #16a34a;
  box-shadow: 0 0 0 6rpx rgba(22, 163, 74, 0.12);
}

.status-dot.ok {
  background: #16a34a;
  box-shadow: 0 0 0 6rpx rgba(22, 163, 74, 0.12);
}

.status-dot.busy,
.status-dot.warn {
  background: #f59e0b;
  box-shadow: 0 0 0 6rpx rgba(245, 158, 11, 0.14);
}

.status-dot.danger {
  background: #ef4444;
  box-shadow: 0 0 0 6rpx rgba(239, 68, 68, 0.12);
}

.compact-main {
  min-width: 0;
  flex: 1;
}

.compact-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.type-chip {
  flex: 0 0 auto;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  color: #b45309;
  background: #fef3c7;
  font-size: 18rpx;
  font-weight: 900;
}

.compact-no {
  min-width: 0;
  color: var(--c-primary-dark);
  font-size: 21rpx;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-price {
  flex: 0 0 auto;
  color: var(--c-text);
  font-size: 20rpx;
  font-weight: 900;
}

.compact-line {
  margin-top: 5rpx;
  color: var(--c-text);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-meta {
  margin-top: 4rpx;
  color: var(--c-muted);
  font-size: 19rpx;
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-actions {
  flex: 0 0 auto;
  display: grid;
  gap: 6rpx;
}

.mini-btn {
  width: 60rpx;
  height: 36rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 18rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.compact-confirm {
  width: 64rpx;
}

.empty-line {
  padding: 24rpx 0;
  color: var(--c-muted);
  font-size: 23rpx;
  text-align: center;
}

.edit-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
}

.input {
  box-sizing: border-box;
  height: 64rpx;
  padding: 0 14rpx;
  border-radius: 17rpx;
  border: 1rpx solid var(--c-border);
  color: var(--c-text);
  background: #f8fafc;
  font-size: 23rpx;
}

.edit-actions {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.small-button {
  height: 58rpx;
  min-width: 0;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 18rpx;
  color: #334155;
  background: #f1f5f9;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 58rpx;
}

.small-button.primary {
  color: #ffffff;
  background: var(--c-primary);
}

.resource-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.resource-scroll {
  height: 328rpx;
  margin-top: 10rpx;
}

.resource-row {
  min-height: 56rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 18rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 7rpx;
  padding: 8rpx 10rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border);
  background: #ffffff;
}

.resource-row.driver-row {
  grid-template-columns: 18rpx minmax(0, 1fr);
}

.resource-row.selected {
  border-color: var(--c-primary);
  background: var(--c-primary-soft);
}

.resource-row.disabled {
  opacity: 0.58;
}

.resource-name {
  min-width: 0;
  color: var(--c-text);
  font-size: 23rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.resource-sub {
  max-width: 112rpx;
  color: var(--c-muted);
  font-size: 18rpx;
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dispatch-preview {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: 30rpx;
  z-index: 20;
  border-radius: 26rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 168rpx;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  background: #ffffff;
  color: var(--c-text);
  border: 1rpx solid var(--c-border);
  box-shadow: 0 20rpx 46rpx rgba(30, 54, 92, 0.16);
}

.preview-title {
  font-size: 24rpx;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-sub {
  margin-top: 4rpx;
  color: var(--c-muted);
  font-size: 19rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 7rpx;
}

.dispatch-button {
  height: 58rpx;
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 900;
  border: 0;
  padding: 0;
}

.dispatch-button.secondary {
  color: #1d4ed8;
  background: #eff6ff;
}

.dispatch-button.ready {
  background: var(--c-primary);
}

.dispatch-button.disabled {
  background: #e2e8f0;
  color: #94a3b8;
}

.conflict,
.success-text {
  margin-top: 14rpx;
  border-radius: 20rpx;
  padding: 14rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.conflict {
  color: #991b1b;
  background: #fee2e2;
}

.success-text {
  color: #166534;
  background: #dcfce7;
}
