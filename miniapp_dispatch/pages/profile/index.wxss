@import "../../app.wxss";

.profile-hero {
  background: linear-gradient(135deg, #1748c7 0%, #246bfe 100%);
}

.profile-list {
  margin-top: 12rpx;
}

.profile-row {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--c-border);
}

.profile-row:last-child {
  border-bottom: 0;
}

.profile-row text {
  color: var(--c-muted);
  font-size: 24rpx;
  font-weight: 750;
}

.profile-row strong {
  min-width: 0;
  color: var(--c-text);
  font-size: 25rpx;
  font-weight: 900;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
