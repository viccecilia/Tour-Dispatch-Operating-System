<view class="page {{isTealTheme ? 'driver-theme' : ''}}">
  <view class="hero profile-hero">
    <view class="hero-eyebrow">{{isDriverTheme ? 'DRIVER PROFILE' : 'ACCOUNT PROFILE'}}</view>
    <view class="hero-title">{{session.dispatcher.dispatcher_name || '未登录'}}</view>
    <view class="hero-meta">{{session.dispatcher.dispatcher_code || '-'}} · {{roleLabel}}</view>
  </view>

  <block wx:if="{{isDriverTheme}}">
    <view class="panel">
      <view class="panel-title">联系方式</view>
      <view class="profile-form">
        <view wx:for="{{contactFields}}" wx:key="key" class="field">
          <view class="field-label">{{item.label}}</view>
          <input class="input profile-input" value="{{contactForm[item.key]}}" data-key="{{item.key}}" bindinput="onInput" placeholder="{{item.placeholder}}" />
        </view>
      </view>
      <button class="button-primary profile-save" loading="{{saving}}" bindtap="saveDriverProfile">保存联系方式</button>
    </view>

    <view class="panel">
      <view class="panel-title">证件与健康体检</view>
      <view class="document-block">
        <view class="document-head">
          <view>
            <view class="row-title">驾照</view>
            <view class="muted">上传驾照照片并填写到期时间，后台可查看。</view>
          </view>
          <view class="doc-status">{{driver.license_file_url ? '已上传' : '未上传'}}</view>
        </view>
        <input class="input profile-input" value="{{contactForm.license_due_date}}" data-key="license_due_date" bindinput="onInput" placeholder="驾照到期日 YYYY-MM-DD" />
        <button class="button-secondary upload-button" loading="{{saving}}" bindtap="uploadLicense">上传驾照照片</button>
      </view>

      <view class="document-block">
        <view class="document-head">
          <view>
            <view class="row-title">健康体检</view>
            <view class="muted">上传体检照片并填写体检日期；有效期按 365 天计算。</view>
          </view>
          <view class="doc-status">{{driver.health_check_file_url ? '已上传' : '未上传'}}</view>
        </view>
        <input class="input profile-input" value="{{contactForm.health_check_due_date}}" data-key="health_check_due_date" bindinput="onInput" placeholder="体检日期 YYYY-MM-DD" />
        <button class="button-secondary upload-button" loading="{{saving}}" bindtap="uploadHealthCheck">上传体检照片</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="panel">
      <view class="panel-title">账号信息</view>
      <view class="profile-list">
        <view class="profile-row"><text>姓名</text><strong>{{session.dispatcher.dispatcher_name || '-'}}</strong></view>
        <view class="profile-row"><text>账号代码</text><strong>{{session.dispatcher.dispatcher_code || '-'}}</strong></view>
        <view class="profile-row"><text>角色</text><strong>{{roleLabel}}</strong></view>
        <view class="profile-row"><text>手机号</text><strong>{{session.user.phone || session.dispatcher.phone || '-'}}</strong></view>
      </view>
    </view>

    <view wx:if="{{canFinance}}" class="panel finance-card">
      <view class="panel-title">财务概览</view>
      <view class="finance-focus-grid">
        <view class="finance-focus">
          <text>今日金额</text>
          <strong>¥{{financeSummary.today_amount || 0}}</strong>
        </view>
        <view class="finance-focus warning">
          <text>待确认费用</text>
          <strong>¥{{financeSummary.pending_amount || 0}}</strong>
        </view>
        <view class="finance-focus">
          <text>司机垫付</text>
          <strong>¥{{financeSummary.driver_advance_total || 0}}</strong>
        </view>
        <view class="finance-focus success">
          <text>司机代收</text>
          <strong>¥{{financeSummary.driver_collect_total || 0}}</strong>
        </view>
      </view>
      <view class="finance-list">
        <view wx:for="{{financeOrders}}" wx:key="order_id" class="finance-row">
          <view>
            <view class="row-title">{{item.oid || item.order_id}}</view>
            <view class="muted">{{item.order_date}} {{item.start_time || ''}} · {{item.driver_name || '未派司机'}}</view>
          </view>
          <view class="amount">¥{{item.price || 0}}</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{message}}" class="panel muted">{{message}}</view>

  <view class="panel stack">
    <button class="button-primary" bindtap="logout">退出登录</button>
  </view>
  <custom-tab-bar />
</view>
