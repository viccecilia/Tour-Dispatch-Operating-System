<view class="page">
  <view class="hero">
    <view class="hero-eyebrow">DISPATCHER PROFILE</view>
    <view class="hero-title">{{session.dispatcher.dispatcher_name || '未登录'}}</view>
    <view class="hero-meta">{{session.dispatcher.dispatcher_code || '-'}} · {{session.dispatcher.dispatcher_role || '-'}}</view>
  </view>

  <view class="panel">
    <view class="panel-title">共享数据库状态</view>
    <view class="grid">
      <view class="metric"><text>orders</text><strong>{{shared.tables.orders || 0}}</strong></view>
      <view class="metric"><text>drafts</text><strong>{{shared.tables.drafts || 0}}</strong></view>
      <view class="metric"><text>assignments</text><strong>{{shared.tables.assignments || 0}}</strong></view>
      <view class="metric"><text>notifications</text><strong>{{shared.tables.notifications || 0}}</strong></view>
    </view>
    <view class="muted">API：{{baseUrl}}</view>
  </view>

  <view class="panel stack">
    <button class="button-secondary" bindtap="loadShared">刷新共享状态</button>
    <button class="button-primary" bindtap="logout">退出登录</button>
  </view>
</view>
