<view class="page">
  <view class="hero">
    <view class="hero-eyebrow">GLOBAL SEARCH</view>
    <view class="hero-title">全局搜索</view>
    <view class="hero-meta">订单 / 客人 / 手机 / 司机 / 车牌 / 地点</view>
  </view>

  <view class="panel">
    <input class="input" value="{{query}}" bindinput="onQuery" placeholder="输入关键词" confirm-type="search" />
    <view class="search-tabs">
      <view data-mode="orders" bindtap="setMode" class="{{mode === 'orders' ? 'active' : ''}}">订单</view>
      <view data-mode="drivers" bindtap="setMode" class="{{mode === 'drivers' ? 'active' : ''}}">司机</view>
      <view data-mode="vehicles" bindtap="setMode" class="{{mode === 'vehicles' ? 'active' : ''}}">车辆</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">搜索结果</view>
    <view class="list">
      <view wx:for="{{results}}" wx:key="key" class="row">
        <view>
          <view class="row-title">{{item.title}}</view>
          <view class="muted">{{item.meta}}</view>
        </view>
        <text class="result-badge">{{item.badge}}</text>
      </view>
      <view wx:if="{{!results.length}}" class="muted">暂无匹配结果。</view>
    </view>
  </view>
</view>
