<view class="page driver-theme">
  <view class="hero expense-hero">
    <view class="hero-eyebrow">DRIVER EXPENSES</view>
    <view class="hero-title">费用</view>
    <view class="hero-meta">垫付、代收和司机收入记录。</view>
  </view>

  <view class="panel">
    <view class="panel-title">提交费用</view>
    <view class="expense-form">
      <view class="field">
        <view class="field-label">类型</view>
        <picker range="{{['垫付', '代收']}}" bindchange="onKindChange">
          <view class="input expense-input picker-cell">
            <text>{{form.expense_kind === 'collect' ? '代收' : '垫付'}}</text>
            <text class="picker-arrow">切换</text>
          </view>
        </picker>
      </view>
      <view class="field">
        <view class="field-label">金额</view>
        <input class="input expense-input" type="digit" data-key="amount" bindinput="onInput" value="{{form.amount}}" placeholder="请输入金额" />
      </view>
      <view class="field">
        <view class="field-label">备注</view>
        <input class="input expense-input" data-key="note" bindinput="onInput" value="{{form.note}}" placeholder="例如停车费、高速费、代收说明" />
      </view>
      <button class="button-primary submit-button" bindtap="submitExpense">提交</button>
    </view>
  </view>

  <view class="panel">
    <view class="panel-header-lite">
      <view>
        <view class="panel-title">费用记录</view>
        <view class="muted">只显示当前司机自己的费用。</view>
      </view>
      <view class="soft-count">{{expenses.length}} 条</view>
    </view>
    <view class="expense-list">
      <view wx:for="{{expenses}}" wx:key="id" class="expense-row">
        <view>
          <view class="row-title">{{item.expense_kind || item.category || '费用'}}</view>
          <view class="muted">{{item.note || '-'}} · {{item.created_at || item.reported_at || ''}}</view>
        </view>
        <view class="amount">¥{{item.amount || 0}}</view>
      </view>
      <view wx:if="{{!expenses.length && !loading}}" class="empty-state">暂无费用记录。</view>
    </view>
  </view>

  <view wx:if="{{message}}" class="panel muted">{{message}}</view>
  <custom-tab-bar />
</view>
