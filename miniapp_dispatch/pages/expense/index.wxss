@import "../../app.wxss";

.expense-hero {
  background: linear-gradient(135deg, #1748c7 0%, #246bfe 100%);
}

.driver-theme .expense-hero {
  background: linear-gradient(135deg, #155e75 0%, #0f766e 100%);
}

.expense-form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.field-label {
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 850;
}

.expense-input {
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.picker-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: var(--c-primary);
  font-size: 22rpx;
  font-weight: 900;
}

.receipt-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 22rpx;
  background: #f8fafc;
}

.receipt-title {
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 900;
}

.receipt-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 0 0 180rpx;
}

.compact-button {
  width: 100%;
  min-height: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.button-ghost {
  color: #64748b;
  background: #eef2f7;
}

.submit-button {
  margin-top: 8rpx;
}

.expense-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.expense-row {
  min-height: 104rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid var(--c-border);
}

.expense-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.expense-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.expense-tags text {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #0f766e;
  background: #e6fffb;
  font-size: 20rpx;
  font-weight: 850;
}

.message-line {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 850;
}
