<view class="page">
  <view class="hero">
    <view class="hero-eyebrow">DISPATCH MOBILE</view>
    <view class="hero-title">{{session ? session.dispatcher.dispatcher_name : '调度员登录'}}</view>
    <view class="hero-meta">{{session ? session.dispatcher.dispatcher_code + ' · ' + session.dispatcher.dispatcher_role : '移动调度运行入口'}}</view>
  </view>

  <view wx:if="{{!session}}" class="panel stack">
    <view class="panel-title">账号登录</view>
    <input class="input" value="{{username}}" bindinput="onUsername" placeholder="用户名" />
    <input class="input" value="{{password}}" password bindinput="onPassword" placeholder="密码" />
    <button class="button-primary" loading="{{loading}}" bindtap="login">进入移动调度</button>
    <view wx:if="{{error}}" class="muted">{{error}}</view>
  </view>

  <view wx:else>
    <view class="todo-panel">
      <view class="todo-head">
        <view>
          <view class="section-kicker">TODAY OPS</view>
          <view class="todo-title">调度待办中心</view>
        </view>
        <view class="live-pill">运行中</view>
      </view>
      <view class="todo-grid">
        <view class="todo-card primary" bindtap="goDispatch">
          <text>未派车</text>
          <strong>{{dashboard.counts.unassigned_orders || 0}}</strong>
          <view>优先处理</view>
        </view>
        <view class="todo-card warning">
          <text>待确认</text>
          <strong>{{dashboard.counts.pending_confirmations || 0}}</strong>
          <view>司机回执</view>
        </view>
        <view class="todo-card danger">
          <text>高风险</text>
          <strong>{{dashboard.counts.exception_orders || dashboard.counts.incident_orders || 0}}</strong>
          <view>异常/延误</view>
        </view>
        <view class="todo-card">
          <text>今日订单</text>
          <strong>{{dashboard.counts.today_orders || 0}}</strong>
          <view>全量</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-header-lite">
        <view>
          <view class="panel-title">调度压力</view>
          <view class="muted">红黄风险和连续工作司机。</view>
        </view>
        <view class="soft-count">{{driverStats.length}}人</view>
      </view>
      <view class="pressure-list">
        <view class="pressure-row {{item.alert ? 'danger' : ''}}" wx:for="{{driverStats}}" wx:key="driver_id">
          <view>
            <view class="pressure-name">{{item.driver_name}}</view>
            <view class="muted">今日 {{item.today_orders}} 单 · 本月 {{item.month_orders}} 单</view>
          </view>
          <view class="pressure-badge {{item.alert ? 'danger' : ''}}">连续 {{item.continuous_days}} 天</view>
        </view>
      </view>
      <view wx:if="{{!driverStats.length}}" class="muted">暂无司机订单统计。</view>
    </view>

    <view class="panel">
      <view class="panel-title">关键通知</view>
      <view class="list">
        <view wx:for="{{notifications}}" wx:key="id" class="row">
          <view class="row-title">{{item.title}}</view>
          <view class="muted">{{item.notification_type}} · {{item.priority}} · {{item.status}}</view>
        </view>
        <view wx:if="{{!notifications.length}}" class="muted">暂无关键通知。</view>
      </view>
    </view>

    <view class="grid">
      <button class="button-secondary" bindtap="goDispatch">去派车</button>
      <button class="button-secondary" bindtap="goFinance">查看财务</button>
    </view>
  </view>
</view>
