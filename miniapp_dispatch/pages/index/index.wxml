<view class="page">
  <view class="hero dashboard-hero">
    <view class="hero-eyebrow">TOURFLOW DISPATCH</view>
    <view class="hero-title">{{session ? session.dispatcher.dispatcher_name : '调度员登录'}}</view>
    <view class="hero-meta">{{session ? session.dispatcher.dispatcher_code + ' · ' + session.dispatcher.dispatcher_role : '移动调度运行入口'}}</view>
  </view>

  <view wx:if="{{!session}}" class="panel stack login-panel">
    <view>
      <view class="panel-title">账号登录</view>
      <view class="login-help">测试账号：admin / admin123；手机号账号使用手机号和后 4 位密码。</view>
    </view>
    <input class="input login-input" value="{{username}}" bindinput="onUsername" placeholder="用户名或手机号" />
    <input class="input login-input" value="{{password}}" password bindinput="onPassword" placeholder="密码" />
    <button class="button-primary" loading="{{loading}}" bindtap="login">进入移动调度</button>
    <view wx:if="{{error}}" class="muted">{{error}}</view>
  </view>

  <view wx:else>
    <view class="ops-summary">
      <view class="summary-main" bindtap="goDispatch">
        <view class="summary-label">未派车</view>
        <view class="summary-number">{{dashboard.counts.unassigned_orders || 0}}</view>
        <view class="summary-note">点击进入派车工作台</view>
      </view>
      <view class="summary-side">
        <view class="summary-chip"><text>今日订单</text><strong>{{dashboard.counts.today_orders || 0}}</strong></view>
        <view class="summary-chip"><text>待确认</text><strong>{{dashboard.counts.pending_confirmations || 0}}</strong></view>
      </view>
    </view>

    <view class="status-strip">
      <view class="status-card good">
        <text>在线司机</text>
        <strong>{{dashboard.counts.online_drivers || 0}}</strong>
      </view>
      <view class="status-card warn">
        <text>异常订单</text>
        <strong>{{dashboard.counts.exception_orders || dashboard.counts.incident_orders || 0}}</strong>
      </view>
      <view class="status-card notice" bindtap="scrollToNotifications">
        <text>未读通知</text>
        <strong>{{dashboard.counts.notifications_unread || 0}}</strong>
      </view>
    </view>

    <view class="panel">
      <view class="panel-header-lite">
        <view>
          <view class="panel-title">司机工作压力</view>
          <view class="muted">连续工作超过 13 天会标记为风险。</view>
        </view>
        <view class="soft-count">{{driverStats.length}} 人</view>
      </view>
      <view class="pressure-list">
        <view class="pressure-row {{item.alert ? 'danger' : ''}}" wx:for="{{visibleDriverStats}}" wx:key="driver_id">
          <view>
            <view class="pressure-name">{{item.driver_name}}</view>
            <view class="muted">今日 {{item.today_orders}} 单 · 本月 {{item.month_orders}} 单</view>
          </view>
          <view class="pressure-badge {{item.alert ? 'danger' : ''}}">连续 {{item.continuous_days}} 天</view>
        </view>
      </view>
      <view wx:if="{{driverStats.length > 3}}" class="pressure-toggle" bindtap="togglePressureList">
        {{pressureExpanded ? '收起，只看前 3 人' : '展开全部司机'}}
      </view>
      <view wx:if="{{!driverStats.length}}" class="empty-state">暂无司机订单统计</view>
    </view>

    <view class="panel notifications-panel">
      <view class="panel-header-lite">
        <view>
          <view class="panel-title">关键通知</view>
          <view class="muted">派车、司机报备、异常、到期提醒和规则提醒会显示在这里。</view>
        </view>
        <view class="soft-count" bindtap="toggleNotifications">{{notificationExpanded ? '收起' : '查看'}}</view>
      </view>
      <view class="list">
        <view wx:for="{{notifications}}" wx:key="id" wx:if="{{notificationExpanded || index < 3}}" data-id="{{item.id}}" bindtap="onNotificationTap" class="row notification-row {{item.isUnread ? 'unread' : ''}}">
          <view class="notification-dot {{item.priority}}"></view>
          <view class="notification-main">
            <view class="row-title">{{item.title || item.typeText}}</view>
            <view class="muted">{{item.typeText}} · {{item.priorityText}} · {{item.statusText}}</view>
            <view wx:if="{{item.body}}" class="notification-body">{{item.body}}</view>
          </view>
          <view class="notification-action">详情</view>
        </view>
        <view wx:if="{{!notifications.length}}" class="empty-state">暂无关键通知</view>
      </view>
    </view>

    <view class="quick-actions">
      <button class="button-secondary" bindtap="goDispatch">去派车</button>
      <button class="button-secondary" bindtap="goFinance">看财务</button>
    </view>
  </view>
</view>
