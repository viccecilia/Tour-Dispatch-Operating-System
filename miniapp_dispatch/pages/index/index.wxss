@import "../../app.wxss";

.dashboard-hero {
  background: linear-gradient(135deg, #153b92 0%, #246bfe 100%);
}

.driver-theme .dashboard-hero,
.driver-theme .summary-main {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  box-shadow: 0 18rpx 42rpx rgba(20, 184, 166, 0.22);
}

.login-panel {
  gap: 30rpx;
  padding: 36rpx;
}

.login-help {
  margin-top: 8rpx;
  color: var(--c-muted);
  font-size: 24rpx;
  line-height: 1.45;
}

.login-input {
  display: block;
  height: 132rpx;
  min-height: 132rpx;
  line-height: 132rpx;
  box-sizing: border-box;
  padding: 0 36rpx;
  border: 2rpx solid #dbe7f5;
  border-radius: 32rpx;
  background: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.login-placeholder {
  color: #9aa8ba;
  font-size: 34rpx;
  font-weight: 750;
}

.login-panel .button-primary {
  width: 100%;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 32rpx;
  font-size: 36rpx;
}

.ops-summary {
  display: grid;
  grid-template-columns: 1.18fr 0.82fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.summary-main {
  min-height: 244rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #246bfe 0%, #1748c7 100%);
  box-shadow: 0 18rpx 42rpx rgba(36, 107, 254, 0.22);
}

.summary-main.ops-main {
  background: linear-gradient(135deg, #0f766e 0%, #0ea5a0 52%, #2563eb 100%);
  box-shadow: 0 18rpx 42rpx rgba(15, 118, 110, 0.2);
}

.summary-main.ops-main.warning {
  background: linear-gradient(135deg, #0f766e 0%, #0ea5a0 45%, #f59e0b 100%);
  box-shadow: 0 18rpx 42rpx rgba(245, 158, 11, 0.18);
}

.summary-label,
.summary-note {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 850;
}

.summary-number {
  margin: 14rpx 0;
  font-size: 76rpx;
  font-weight: 950;
  line-height: 1;
}

.summary-number.status-text {
  font-size: 56rpx;
  line-height: 1.08;
}

.summary-side {
  display: grid;
  gap: 16rpx;
}

.summary-chip,
.status-card {
  border-radius: 28rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.summary-chip.active,
.status-card.active {
  border-color: #2563eb;
  box-shadow: 0 12rpx 26rpx rgba(37, 99, 235, 0.14);
}

.driver-theme .summary-chip.active,
.driver-theme .status-card.active {
  border-color: #14b8a6;
  box-shadow: 0 12rpx 26rpx rgba(20, 184, 166, 0.14);
}

.summary-chip text,
.status-card text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.summary-chip strong,
.status-card strong {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: 38rpx;
  font-weight: 950;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.ops-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.ops-grid-compact {
  grid-template-columns: 1fr;
}

.ops-card {
  min-height: 142rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  padding: 20rpx;
  background: #ffffff;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.ops-card.active {
  border-color: #0f766e;
  background: linear-gradient(180deg, #ecfdf5 0%, #ffffff 100%);
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.16);
}

.ops-card text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 850;
}

.ops-card strong {
  display: block;
  margin-top: 8rpx;
  color: #0f766e;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 1;
}

.ops-card view {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 750;
  line-height: 1.35;
}

.ops-detail-grid {
  margin-top: 18rpx;
}

.ops-detail-panel {
  margin-bottom: 18rpx;
}

.ops-detail-panel.single {
  margin-top: 18rpx;
}

.ops-detail-list {
  margin-top: 14rpx;
}

.ops-detail-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.ops-detail-row:last-child {
  border-bottom: 0;
}

.ops-detail-main {
  display: grid;
  gap: 6rpx;
}

.ops-field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
}

.ops-field {
  min-width: 0;
  box-sizing: border-box;
  border-radius: 18rpx;
  padding: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.ops-field text {
  display: block;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 800;
}

.ops-field strong {
  display: block;
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.compact-list {
  margin-top: 14rpx;
}

.compact-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 8rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.compact-row:last-child {
  border-bottom: 0;
}

.compact-body {
  color: #475569;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 1.4;
  word-break: break-all;
}

.ops-home-detail {
  min-height: 360rpx;
}

.ops-mini-fields {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  margin-top: 10rpx;
}

.ops-mini-field {
  min-width: 0;
  border-radius: 16rpx;
  padding: 10rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.ops-mini-field text {
  display: block;
  color: #64748b;
  font-size: 19rpx;
  font-weight: 800;
}

.ops-mini-field strong {
  display: block;
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.status-card.good {
  background: var(--c-success-soft);
  border-color: #bbf7d0;
}

.status-card.warn {
  background: var(--c-warning-soft);
  border-color: #fed7aa;
}

.status-card.notice {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.driver-theme .status-card.notice {
  background: #ecfeff;
  border-color: #99f6e4;
}

.panel-header-lite,
.pressure-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.soft-count {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  color: #15803d;
  background: #dcfce7;
  font-size: 22rpx;
  font-weight: 900;
}

.pressure-list {
  margin-top: 16rpx;
}

.pressure-row {
  min-height: 82rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.pressure-row:last-child {
  border-bottom: 0;
}

.pressure-name {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 900;
}

.pressure-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
  color: #475569;
  background: #f1f5f9;
  font-size: 21rpx;
  font-weight: 900;
}

.pressure-badge.danger {
  color: #b91c1c;
  background: #fee2e2;
}

.pressure-toggle {
  margin-top: 10rpx;
  height: 58rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 23rpx;
  font-weight: 900;
}

.notification-row {
  position: relative;
  display: grid;
  grid-template-columns: 18rpx minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.notification-row:last-child {
  border-bottom: 0;
}

.notification-row.unread .row-title {
  color: var(--c-primary-dark);
}

.notification-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #3b82f6;
  box-shadow: 0 0 0 7rpx rgba(59, 130, 246, 0.12);
}

.driver-theme .notification-dot {
  background: #14b8a6;
  box-shadow: 0 0 0 7rpx rgba(20, 184, 166, 0.12);
}

.notification-dot.critical,
.notification-dot.high {
  background: #ef4444;
  box-shadow: 0 0 0 7rpx rgba(239, 68, 68, 0.12);
}

.notification-dot.normal {
  background: #f59e0b;
  box-shadow: 0 0 0 7rpx rgba(245, 158, 11, 0.13);
}

.notification-dot.low {
  background: #22c55e;
  box-shadow: 0 0 0 7rpx rgba(34, 197, 94, 0.12);
}

.notification-main {
  min-width: 0;
}

.notification-body {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notification-action {
  flex: 0 0 auto;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 21rpx;
  font-weight: 900;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}
