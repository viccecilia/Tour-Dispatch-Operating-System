@import "../../app.wxss";

.dashboard-hero {
  background: linear-gradient(135deg, #153b92 0%, #246bfe 100%);
}

.login-panel {
  gap: 22rpx;
  padding: 30rpx;
}

.login-help {
  margin-top: 8rpx;
  color: var(--c-muted);
  font-size: 24rpx;
  line-height: 1.45;
}

.login-input {
  min-height: 96rpx;
  padding: 0 28rpx;
  border-radius: 26rpx;
  background: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.14);
}

.ops-summary {
  display: grid;
  grid-template-columns: 1.18fr 0.82fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.summary-main {
  min-height: 244rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #246bfe 0%, #1748c7 100%);
  box-shadow: 0 18rpx 42rpx rgba(36, 107, 254, 0.22);
}

.summary-label,
.summary-note {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 850;
}

.summary-number {
  margin: 14rpx 0;
  font-size: 76rpx;
  font-weight: 950;
  line-height: 1;
}

.summary-side {
  display: grid;
  gap: 16rpx;
}

.summary-chip,
.status-card {
  border-radius: 28rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.summary-chip text,
.status-card text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.summary-chip strong,
.status-card strong {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: 38rpx;
  font-weight: 950;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.status-card.good {
  background: var(--c-success-soft);
  border-color: #bbf7d0;
}

.status-card.warn {
  background: var(--c-warning-soft);
  border-color: #fed7aa;
}

.status-card.notice {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.panel-header-lite,
.pressure-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.soft-count {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  color: #15803d;
  background: #dcfce7;
  font-size: 22rpx;
  font-weight: 900;
}

.pressure-list {
  margin-top: 16rpx;
}

.pressure-row {
  min-height: 82rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.pressure-row:last-child {
  border-bottom: 0;
}

.pressure-name {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 900;
}

.pressure-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
  color: #475569;
  background: #f1f5f9;
  font-size: 21rpx;
  font-weight: 900;
}

.pressure-badge.danger {
  color: #b91c1c;
  background: #fee2e2;
}

.pressure-toggle {
  margin-top: 10rpx;
  height: 58rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 23rpx;
  font-weight: 900;
}

.notification-row {
  position: relative;
  display: grid;
  grid-template-columns: 18rpx minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.notification-row:last-child {
  border-bottom: 0;
}

.notification-row.unread .row-title {
  color: var(--c-primary-dark);
}

.notification-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #3b82f6;
  box-shadow: 0 0 0 7rpx rgba(59, 130, 246, 0.12);
}

.notification-dot.critical,
.notification-dot.high {
  background: #ef4444;
  box-shadow: 0 0 0 7rpx rgba(239, 68, 68, 0.12);
}

.notification-dot.normal {
  background: #f59e0b;
  box-shadow: 0 0 0 7rpx rgba(245, 158, 11, 0.13);
}

.notification-dot.low {
  background: #22c55e;
  box-shadow: 0 0 0 7rpx rgba(34, 197, 94, 0.12);
}

.notification-main {
  min-width: 0;
}

.notification-body {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notification-action {
  flex: 0 0 auto;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 21rpx;
  font-weight: 900;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}
