@import "../../app.wxss";

.dashboard-hero {
  background: linear-gradient(135deg, #153b92 0%, #246bfe 100%);
}

.ops-summary {
  display: grid;
  grid-template-columns: 1.18fr 0.82fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.summary-main {
  min-height: 244rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #246bfe 0%, #1748c7 100%);
  box-shadow: 0 18rpx 42rpx rgba(36, 107, 254, 0.22);
}

.summary-label,
.summary-note {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 850;
}

.summary-number {
  margin: 14rpx 0;
  font-size: 76rpx;
  font-weight: 950;
  line-height: 1;
}

.summary-side {
  display: grid;
  gap: 16rpx;
}

.summary-chip,
.status-card {
  border-radius: 28rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.summary-chip text,
.status-card text {
  display: block;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.summary-chip strong,
.status-card strong {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: 38rpx;
  font-weight: 950;
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.status-card.good {
  background: var(--c-success-soft);
  border-color: #bbf7d0;
}

.status-card.warn {
  background: var(--c-warning-soft);
  border-color: #fed7aa;
}

.panel-header-lite,
.pressure-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.soft-count {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  color: #15803d;
  background: #dcfce7;
  font-size: 22rpx;
  font-weight: 900;
}

.pressure-list {
  margin-top: 16rpx;
}

.pressure-row {
  min-height: 82rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.pressure-row:last-child {
  border-bottom: 0;
}

.pressure-name {
  color: var(--c-text);
  font-size: 27rpx;
  font-weight: 900;
}

.pressure-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
  color: #475569;
  background: #f1f5f9;
  font-size: 21rpx;
  font-weight: 900;
}

.pressure-badge.danger {
  color: #b91c1c;
  background: #fee2e2;
}

.pressure-toggle {
  margin-top: 10rpx;
  height: 58rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-primary-dark);
  background: var(--c-primary-soft);
  font-size: 23rpx;
  font-weight: 900;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}
