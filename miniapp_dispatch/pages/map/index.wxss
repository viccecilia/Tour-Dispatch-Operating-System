@import "../../app.wxss";

.map-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #dbeafe;
}

.fleet-map {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  z-index: 5;
  border-radius: 34rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--shadow-floating);
  backdrop-filter: blur(18rpx);
}

.map-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.title-with-help {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.help-dot {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 30rpx;
  height: 30rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: #eef2f7;
  border: 1rpx solid #dbe3ee;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1;
}

.map-eyebrow {
  color: var(--c-primary);
  font-size: 20rpx;
  font-weight: 900;
}

.map-title {
  margin-top: 4rpx;
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 950;
}

.refresh-button {
  flex: 0 0 auto;
  min-width: 92rpx;
  max-width: 124rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 0;
  border-radius: 999rpx;
  background: var(--c-primary);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 48rpx;
  padding: 0 14rpx;
}

.refresh-button::after {
  border: 0;
}

.help-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(15, 23, 42, 0.08);
}

.help-popover {
  position: fixed;
  top: 152rpx;
  left: 28rpx;
  right: 28rpx;
  z-index: 81;
  padding: 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe3ee;
  background: #ffffff;
  box-shadow: 0 22rpx 52rpx rgba(15, 23, 42, 0.16);
}

.help-popover-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.help-popover-title {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 950;
}

.help-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: #f1f5f9;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.help-popover-body {
  margin-top: 12rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.5;
}

.map-alert-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.map-alert-row view {
  min-width: 0;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid var(--c-border);
}

.map-alert-row text {
  display: block;
  color: var(--c-muted);
  font-size: 20rpx;
  font-weight: 800;
}

.map-alert-row strong {
  display: block;
  margin-top: 4rpx;
  color: var(--c-text);
  font-size: 28rpx;
  font-weight: 950;
}

.search-box {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background: #f1f5f9;
  border: 1rpx solid var(--c-border);
}

.search-box input {
  width: 100%;
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mode-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  background: #eef3fb;
  font-size: 24rpx;
  font-weight: 900;
}

.mode-tab.active {
  color: #ffffff;
  background: var(--c-primary);
}

.map-bottom {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(132rpx + env(safe-area-inset-bottom));
  z-index: 5;
  border-radius: 34rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--shadow-floating);
  backdrop-filter: blur(18rpx);
}

.selected-card {
  margin-bottom: 14rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: var(--c-primary-soft);
  border: 1rpx solid #bfdbfe;
}

.selected-title {
  color: var(--c-text);
  font-size: 28rpx;
  font-weight: 950;
}

.selected-meta,
.selected-sub {
  margin-top: 6rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.35;
}

.result-list {
  max-height: 310rpx;
}

.result-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx 6rpx;
  border-bottom: 1rpx solid var(--c-border);
}

.result-row:last-child {
  border-bottom: 0;
}

.result-title {
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 900;
}

.result-meta {
  margin-top: 6rpx;
  color: var(--c-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.result-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 7rpx 12rpx;
  color: var(--c-muted);
  background: #f1f5f9;
  font-size: 20rpx;
  font-weight: 850;
}

.result-badge.online {
  color: #15803d;
  background: #dcfce7;
}

.driver-map-page {
  background: #f0fdfa;
}

.driver-task-panel {
  border: 1rpx solid rgba(20, 184, 166, 0.22);
}

.driver-task-panel .map-eyebrow {
  color: #0f766e;
}

.driver-task-panel .refresh-button,
.node-action {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
}

.current-task-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: #f8fafc;
  border: 1rpx solid #ccfbf1;
}

.current-order {
  margin-top: 12rpx;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 950;
}

.current-time {
  margin-top: 6rpx;
  color: var(--c-muted);
  font-size: 23rpx;
  font-weight: 800;
}

.current-route {
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 900;
}

.node-action {
  width: 100%;
  height: 72rpx;
  line-height: normal;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 950;
  box-shadow: 0 14rpx 28rpx rgba(20, 184, 166, 0.22);
}

.node-action::after {
  border: 0;
}

.empty-current {
  background: #ffffff;
}

.driver-upcoming-panel {
  max-height: 360rpx;
}

.compact-task {
  min-height: 78rpx;
}
