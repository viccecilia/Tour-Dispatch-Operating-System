@import "../../app.wxss";

.map-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #dbeafe;
}

.fleet-map {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  z-index: 5;
  border-radius: 34rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--shadow-floating);
  backdrop-filter: blur(18rpx);
}

.map-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.map-eyebrow {
  color: var(--c-primary);
  font-size: 20rpx;
  font-weight: 900;
}

.map-title {
  margin-top: 4rpx;
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 950;
}

.refresh-button {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 64rpx;
  border: 0;
  border-radius: 20rpx;
  background: var(--c-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.refresh-button::after {
  border: 0;
}

.map-alert-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.map-alert-row view {
  min-width: 0;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid var(--c-border);
}

.map-alert-row text {
  display: block;
  color: var(--c-muted);
  font-size: 20rpx;
  font-weight: 800;
}

.map-alert-row strong {
  display: block;
  margin-top: 4rpx;
  color: var(--c-text);
  font-size: 28rpx;
  font-weight: 950;
}

.search-box {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background: #f1f5f9;
  border: 1rpx solid var(--c-border);
}

.search-box input {
  width: 100%;
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mode-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  background: #eef3fb;
  font-size: 24rpx;
  font-weight: 900;
}

.mode-tab.active {
  color: #ffffff;
  background: var(--c-primary);
}

.map-bottom {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 24rpx;
  z-index: 5;
  border-radius: 34rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--shadow-floating);
  backdrop-filter: blur(18rpx);
}

.selected-card {
  margin-bottom: 14rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: var(--c-primary-soft);
  border: 1rpx solid #bfdbfe;
}

.selected-title {
  color: var(--c-text);
  font-size: 28rpx;
  font-weight: 950;
}

.selected-meta,
.selected-sub {
  margin-top: 6rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.35;
}

.result-list {
  max-height: 310rpx;
}

.result-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx 6rpx;
  border-bottom: 1rpx solid var(--c-border);
}

.result-row:last-child {
  border-bottom: 0;
}

.result-title {
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 900;
}

.result-meta {
  margin-top: 6rpx;
  color: var(--c-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.result-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 7rpx 12rpx;
  color: var(--c-muted);
  background: #f1f5f9;
  font-size: 20rpx;
  font-weight: 850;
}

.result-badge.online {
  color: #15803d;
  background: #dcfce7;
}
