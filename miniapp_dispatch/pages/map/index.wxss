@import "../../app.wxss";

.map-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #0f172a;
}

.fleet-map {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  z-index: 5;
  border-radius: 30rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.2);
  backdrop-filter: blur(18rpx);
}

.map-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.map-eyebrow {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.map-title {
  margin-top: 4rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 950;
}

.refresh-button {
  flex: 0 0 auto;
  min-width: 108rpx;
  height: 62rpx;
  border: 0;
  border-radius: 18rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.search-box {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background: #f1f5f9;
  border: 1rpx solid #dbe4f0;
}

.search-box input {
  width: 100%;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mode-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  background: #eef3fb;
  font-size: 24rpx;
  font-weight: 900;
}

.mode-tab.active {
  color: #ffffff;
  background: #2563eb;
}

.map-bottom {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 24rpx;
  z-index: 5;
  border-radius: 30rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 20rpx 52rpx rgba(15, 23, 42, 0.24);
  backdrop-filter: blur(18rpx);
}

.selected-card {
  margin-bottom: 14rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.selected-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 950;
}

.selected-meta,
.selected-sub {
  margin-top: 6rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.35;
}

.result-list {
  max-height: 310rpx;
}

.result-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx 6rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.result-row:last-child {
  border-bottom: 0;
}

.result-title {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 900;
}

.result-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.35;
}

.result-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 7rpx 12rpx;
  color: #64748b;
  background: #f1f5f9;
  font-size: 20rpx;
  font-weight: 850;
}

.result-badge.online {
  color: #15803d;
  background: #dcfce7;
}
