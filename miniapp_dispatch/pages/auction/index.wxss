@import "../../app.wxss";

.auction-hero {
  background: linear-gradient(135deg, #92400e 0%, #f59e0b 100%);
}

.publish-panel {
  margin-top: 18rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mini-button {
  flex: 0 0 auto;
  min-width: 136rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.mini-button::after {
  border: 0;
}

.draft-list,
.auction-list {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
}

.draft-row,
.auction-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #fed7aa;
  border-radius: 24rpx;
  background: #fffaf3;
}

.price-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fffbeb;
  color: #92400e;
  font-size: 22rpx;
  font-weight: 950;
}

.price-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.price-form .input {
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 22rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  font-weight: 850;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  margin-bottom: 8rpx;
  color: var(--c-muted);
  font-size: 22rpx;
  font-weight: 850;
}

.note-input {
  min-height: 116rpx;
  box-sizing: border-box;
}

.publish-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.message-panel {
  color: #0f766e;
  font-weight: 900;
}

.auction-main {
  min-width: 0;
  flex: 1;
}

.auction-price {
  flex: 0 0 auto;
  min-width: 170rpx;
  display: grid;
  gap: 6rpx;
  text-align: right;
}

.auction-price text {
  color: #b45309;
  font-size: 21rpx;
  font-weight: 850;
}

.auction-price strong {
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 950;
}
